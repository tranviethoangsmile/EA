//+------------------------------------------------------------------+
//|                                     XAU_PRO_V2_OPTIMIZED         |
//+------------------------------------------------------------------+
#property strict
#include <Trade/Trade.mqh>

//--- INPUT PARAMETERS
input group "--- Phân Tích Kỹ Thuật ---"
input int    FastEMA      = 9;
input int    SlowEMA      = 21;
input double ATR_Min      = 2;   
input int    EntryBuffer  = 100;   
input int    RSI_Period   = 14;

input group "--- Quản Lý Vốn & Trailing ---"
input double Hidden_SL    = 10000; 
input double Hidden_TP    = 20000; 
input int    BE_Trigger   = 5000;  
input ulong  Magic        = 240304;

//--- GLOBAL
CTrade trade;
int fastH, slowH, atrH, rsiH;

datetime lastTradeTime = 0;
string brainLog = "Đang phân tích...";

//+------------------------------------------------------------------+

int OnInit()
{
   trade.SetExpertMagicNumber(Magic);

   fastH = iMA(_Symbol, PERIOD_M5, FastEMA, 0, MODE_EMA, PRICE_CLOSE);
   slowH = iMA(_Symbol, PERIOD_M5, SlowEMA, 0, MODE_EMA, PRICE_CLOSE);
   atrH  = iATR(_Symbol, PERIOD_M5, 14);
   rsiH  = iRSI(_Symbol, PERIOD_M5, RSI_Period, PRICE_CLOSE);

   return(INIT_SUCCEEDED);
}

//+------------------------------------------------------------------+

void OnTick()
{
   HandleExit();
   AnalyzeAndTrade();

   Comment("=== XAU SMART AI v2.39 ===\n",
           brainLog,"\n",
           "Equity: ",AccountInfoDouble(ACCOUNT_EQUITY));
}

//+------------------------------------------------------------------+
void AnalyzeAndTrade()
{
   datetime currentTime = iTime(_Symbol, PERIOD_M5, 0);
   if(currentTime == lastTradeTime) return;

   double f[2], s[2], a[1], r[2];

   if(CopyBuffer(fastH,0,0,2,f)<2) return;
   if(CopyBuffer(slowH,0,0,2,s)<2) return;
   if(CopyBuffer(atrH,0,0,1,a)<1) return;
   if(CopyBuffer(rsiH,0,0,2,r)<2) return;

   double ask = SymbolInfoDouble(_Symbol,SYMBOL_ASK);
   double bid = SymbolInfoDouble(_Symbol,SYMBOL_BID);

   double close1 = iClose(_Symbol, PERIOD_M5, 1);
   double open1  = iOpen(_Symbol, PERIOD_M5, 1);

   bool bullishCandle = close1 > open1;
   bool bearishCandle = close1 < open1;

   bool isUpTrend   = (f[1] > s[1] && f[0] > f[1]);
   bool isDownTrend = (f[1] < s[1] && f[0] < f[1]);

   if(a[0] < ATR_Min)
   {
      brainLog="Market yếu";
      return;
   }

   //================ BUY =================
   if(isUpTrend)
   {
      double dist = MathAbs(close1 - f[1])/_Point;

      if(r[1] > 50 && dist < EntryBuffer && bullishCandle)
      {
         if(OpenOrder(ORDER_TYPE_BUY))
         {
            brainLog="BUY pullback confirmed";
            lastTradeTime=currentTime;
         }
      }
      else brainLog="UpTrend: chờ nến xác nhận";
   }

   //================ SELL =================
   else if(isDownTrend)
   {
      double dist = MathAbs(close1 - f[1])/_Point;

      if(r[1] < 50 && dist < EntryBuffer && bearishCandle)
      {
         if(OpenOrder(ORDER_TYPE_SELL))
         {
            brainLog="SELL pullback confirmed";
            lastTradeTime=currentTime;
         }
      }
      else brainLog="DownTrend: chờ nến xác nhận";
   }
}


//+------------------------------------------------------------------+

bool OpenOrder(ENUM_ORDER_TYPE type)
{
   if(PositionsTotal()>0) return false;

   double price=(type==ORDER_TYPE_BUY)?
   SymbolInfoDouble(_Symbol,SYMBOL_ASK):
   SymbolInfoDouble(_Symbol,SYMBOL_BID);

   return trade.PositionOpen(_Symbol,type,0.01,price,0,0,"Optimized Pullback");
}

//+------------------------------------------------------------------+

void HandleExit()
{
   for(int i=PositionsTotal()-1;i>=0;i--)
   {
      ulong ticket=PositionGetTicket(i);

      if(!PositionSelectByTicket(ticket)) continue;
      if(PositionGetInteger(POSITION_MAGIC)!=Magic) continue;

      ENUM_POSITION_TYPE type=(ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);

      double open=PositionGetDouble(POSITION_PRICE_OPEN);

      double price=(type==POSITION_TYPE_BUY)?
      SymbolInfoDouble(_Symbol,SYMBOL_BID):
      SymbolInfoDouble(_Symbol,SYMBOL_ASK);

      double diff=(type==POSITION_TYPE_BUY)?price-open:open-price;

      double points=diff/_Point;

      double sl=PositionGetDouble(POSITION_SL);

      if(points>=BE_Trigger)
      {
         if(type==POSITION_TYPE_BUY && sl<open)
            trade.PositionModify(ticket,open,0);

         if(type==POSITION_TYPE_SELL && (sl==0 || sl>open))
            trade.PositionModify(ticket,open,0);
      }

      if(points>=Hidden_TP || points<=-Hidden_SL)
      {
         trade.PositionClose(ticket);
      }
   }
}