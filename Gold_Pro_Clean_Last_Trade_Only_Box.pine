//@version=5
indicator("Gold Pro Clean - Last Trade Only Box", overlay=true)

// ===== INPUT =====
fastLen = input.int(9, "Fast SMA")
slowLen = input.int(21, "Slow EMA")
rr      = input.float(3.0, "Risk Reward (RR)", minval=1)
lookbackSwing = input.int(20, "Swing Lookback")
extendBars = input.int(60, "Box Extend Bars")

// ===== MA =====
fastMA = ta.sma(close, fastLen)
slowMA = ta.ema(close, slowLen)

plot(fastMA, color=color.blue, linewidth=2)
plot(slowMA, color=color.orange, linewidth=2)

// ===== SIGNAL =====
buySignal  = ta.crossover(fastMA, slowMA)
sellSignal = ta.crossunder(fastMA, slowMA)

// ===== SWING =====
swingLow  = ta.lowest(low, lookbackSwing)
swingHigh = ta.highest(high, lookbackSwing)

// ===== LƯU BOX CUỐI =====
var box slBox = na
var box tpBox = na
var line entryLine = na
var label infoLabel = na

// ===============================
// BUY SIGNAL
// ===============================
if buySignal

    // VẼ SIGNAL (LUÔN HIỂN THỊ)
    label.new(bar_index, low, "BUY",
         style=label.style_label_up,
         color=color.green,
         textcolor=color.white,
         size=size.large)

    entry = close
    sl = swingLow

    if sl < entry
        risk = entry - sl

        if risk > syminfo.mintick * 5

            tp = entry + risk * rr

            // Xoá box cũ
            if not na(slBox)
                box.delete(slBox)
            if not na(tpBox)
                box.delete(tpBox)
            if not na(entryLine)
                line.delete(entryLine)
            if not na(infoLabel)
                label.delete(infoLabel)

            // Vẽ box cho LỆNH MỚI NHẤT
            entryLine := line.new(bar_index, entry,
                 bar_index + extendBars, entry,
                 color=color.white, width=2)

            slBox := box.new(
                 bar_index, entry,
                 bar_index + extendBars, sl,
                 bgcolor=color.new(color.red, 85),
                 border_color=color.red)

            tpBox := box.new(
                 bar_index, tp,
                 bar_index + extendBars, entry,
                 bgcolor=color.new(color.green, 85),
                 border_color=color.green)

            // Thông tin chỉ cho lệnh mới
            infoLabel := label.new(bar_index, entry,
                 "BUY\nEntry: " + str.tostring(entry, format.mintick) +
                 "\nSL: " + str.tostring(sl, format.mintick) +
                 "\nTP: " + str.tostring(tp, format.mintick),
                 style=label.style_label_right,
                 color=color.green,
                 textcolor=color.white,
                 size=size.normal)


// ===============================
// SELL SIGNAL
// ===============================
if sellSignal

    // VẼ SIGNAL (LUÔN HIỂN THỊ)
    label.new(bar_index, high, "SELL",
         style=label.style_label_down,
         color=color.red,
         textcolor=color.white,
         size=size.large)

    entry = close
    sl = swingHigh

    if sl > entry
        risk = sl - entry

        if risk > syminfo.mintick * 5

            tp = entry - risk * rr

            // Xoá box cũ
            if not na(slBox)
                box.delete(slBox)
            if not na(tpBox)
                box.delete(tpBox)
            if not na(entryLine)
                line.delete(entryLine)
            if not na(infoLabel)
                label.delete(infoLabel)

            // Vẽ box cho LỆNH MỚI NHẤT
            entryLine := line.new(bar_index, entry,
                 bar_index + extendBars, entry,
                 color=color.white, width=2)

            slBox := box.new(
                 bar_index, sl,
                 bar_index + extendBars, entry,
                 bgcolor=color.new(color.red, 85),
                 border_color=color.red)

            tpBox := box.new(
                 bar_index, entry,
                 bar_index + extendBars, tp,
                 bgcolor=color.new(color.green, 85),
                 border_color=color.green)

            // Thông tin chỉ cho lệnh mới
            infoLabel := label.new(bar_index, entry,
                 "SELL\nEntry: " + str.tostring(entry, format.mintick) +
                 "\nSL: " + str.tostring(sl, format.mintick) +
                 "\nTP: " + str.tostring(tp, format.mintick),
                 style=label.style_label_right,
                 color=color.red,
                 textcolor=color.white,
                 size=size.normal)
