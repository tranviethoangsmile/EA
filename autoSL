void Track(string n){ int s=ArraySize(gObjs); for(int i=0;i<s;i++) if(gObjs[i]==n) return; ArrayResize(gObjs,s+1); gObjs[s]=n; }
void ObjDeleteAll(){ for(int i=0;i<ArraySize(gObjs);i++) ObjectDelete(0,gObjs[i]); ArrayResize(gObjs,0); ChartRedraw(0); }

void Rect(string n,int x,int y,int w,int h,color bg,color bd,int bw=1)
{
   ObjectCreate(0,n,OBJ_RECTANGLE_LABEL,0,0,0);
   ObjectSetInteger(0,n,OBJPROP_XDISTANCE,x); ObjectSetInteger(0,n,OBJPROP_YDISTANCE,y);
   ObjectSetInteger(0,n,OBJPROP_XSIZE,w);     ObjectSetInteger(0,n,OBJPROP_YSIZE,h);
   ObjectSetInteger(0,n,OBJPROP_BGCOLOR,bg);  ObjectSetInteger(0,n,OBJPROP_COLOR,bd);
   ObjectSetInteger(0,n,OBJPROP_BORDER_TYPE,BORDER_FLAT); ObjectSetInteger(0,n,OBJPROP_WIDTH,bw);
   ObjectSetInteger(0,n,OBJPROP_BACK,false);  ObjectSetInteger(0,n,OBJPROP_SELECTABLE,false);
   ObjectSetInteger(0,n,OBJPROP_ZORDER,0); Track(n);
}

void Lbl(string n,int x,int y,string txt,color clr,int fsize,bool bold=false)
{
   ObjectCreate(0,n,OBJ_LABEL,0,0,0);
   ObjectSetInteger(0,n,OBJPROP_XDISTANCE,x); ObjectSetInteger(0,n,OBJPROP_YDISTANCE,y);
   ObjectSetString(0,n,OBJPROP_TEXT,txt);     ObjectSetInteger(0,n,OBJPROP_COLOR,clr);
   ObjectSetInteger(0,n,OBJPROP_FONTSIZE,fsize); ObjectSetString(0,n,OBJPROP_FONT,bold?"Arial Bold":"Arial");
   ObjectSetInteger(0,n,OBJPROP_CORNER,CORNER_LEFT_UPPER);
   ObjectSetInteger(0,n,OBJPROP_SELECTABLE,false); ObjectSetInteger(0,n,OBJPROP_BACK,false);
   ObjectSetInteger(0,n,OBJPROP_ZORDER,10); Track(n);
}

void Btn(string n,int x,int y,int w,int h,string txt,color bg,color clr,int fsize)
{
   Rect(n+"_bg",x,y,w,h,bg,C_BDR2,1);
   ObjectCreate(0,n,OBJ_LABEL,0,0,0);
   ObjectSetInteger(0,n,OBJPROP_XDISTANCE,x+MathMax(1,(w-(int)StringLen(txt)*fsize)/2));
   ObjectSetInteger(0,n,OBJPROP_YDISTANCE,y+(h-fsize*2)/2+1);
   ObjectSetString(0,n,OBJPROP_TEXT,txt); ObjectSetInteger(0,n,OBJPROP_COLOR,clr);
   ObjectSetInteger(0,n,OBJPROP_FONTSIZE,fsize); ObjectSetString(0,n,OBJPROP_FONT,"Arial Bold");
   ObjectSetInteger(0,n,OBJPROP_CORNER,CORNER_LEFT_UPPER);
   ObjectSetInteger(0,n,OBJPROP_SELECTABLE,true); ObjectSetInteger(0,n,OBJPROP_BACK,false);
   ObjectSetInteger(0,n,OBJPROP_ZORDER,20); Track(n);
}

void ObjTxt(string n,string v)  { ObjectSetString(0,n,OBJPROP_TEXT,v); }
void ObjClr(string n,color v)   { ObjectSetInteger(0,n,OBJPROP_COLOR,v); }
void ObjW(string n,int v)       { ObjectSetInteger(0,n,OBJPROP_XSIZE,v); }
void ObjBg(string n,color v)    { ObjectSetInteger(0,n,OBJPROP_BGCOLOR,v); ObjectSetInteger(0,n,OBJPROP_COLOR,v); }
