//  ╔══════════════════════════════════════════════════════════════════╗
//  ║   MASTER SCALE — GIÁ TRỊ MẶC ĐỊNH KHI KHỞI ĐỘNG               ║
//  ║                                                                  ║
//  ║   80  = nhỏ gọn                                                 ║
//  ║   100 = chuẩn (panel ~480px)                                    ║
//  ║   120 = to hơn 20%  ← khuyến nghị màn HD                      ║
//  ║   150 = to hơn 50%  ← màn 2K/4K                               ║
//  ║   200 = gấp đôi                                                 ║
//  ║                                                                  ║
//  ║   Hoặc dùng nút  [ S ][ M ][ L ][ XL ]  trên dashboard         ║
//  ║   để đổi kích thước NGAY TRÊN BIỂU ĐỒ, không cần recompile!   ║
//  ╚══════════════════════════════════════════════════════════════════╝
//
#define DASH_SCALE  100    // ← giá trị compile-time mặc định (bị ghi đè bởi gDashScale)

//======================================================================
//  SCALING ENGINE — runtime, dùng gDashScale thay DASH_SCALE
//  → toàn bộ panel rebuild ngay khi click nút S/M/L/XL
//======================================================================
#define _SZ(n)   ((int)(((long)(n) * (DASH_SCALE) + 50L) / 100L))   // compile-time (chỉ dùng cho CANVAS_*)
#define _FS(n)   (_SZ(n) < 6 ? 6 : _SZ(n))

int gDashScale = DASH_SCALE;   // ← runtime master scale, thay đổi khi click nút

// Tất cả layout dùng sz()/fs() qua gDashScale — rebuild tức thì khi scale thay đổi
int sz(int n){ return (int)(((long)n * gDashScale + 50L) / 100L); }
int fs(int n){ int v=(int)(((long)n * gDashScale + 50L) / 100L); return v<6?6:v; }

