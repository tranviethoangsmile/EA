void BuildPanel()
{
   ObjDeleteAll();
   int px = InpPanelX;
   int py = InpPanelY;

   // ════════════════════════════════════════════════════════════
   //  KẾT HỢP KÍCH THƯỚC — runtime, tất cả qua sz()/fs()
   // ════════════════════════════════════════════════════════════

   int PW_       = sz(PW_BASE);         // chiều rộng panel
   int MH        = sz(MARGIN_H);        // margin ngang

   // Chiều cao các khối
   int HDR_H     = sz(H_HDR);
   int CRD_H     = sz(H_CRD);
   int SL_H      = sz(H_SL);
   int CD_H      = sz(H_CD);
   int BT_H      = sz(H_BT);
   int RLOG_     = sz(H_RLOG);
   int FT_H      = sz(H_FT);
   int EMA_ACC   = sz(H_EMA_ACC);
   int EMA_SH    = sz(H_EMA_SH);
   int EMA_CV    = CanvasH();           // runtime, = sz(160)
   int EMA_CTRL  = sz(H_EMA_CTRL);
   int EMA_SIG   = sz(H_EMA_SIG);
   int EMA_RSN   = sz(H_EMA_RSN);
   int EMA_SB    = sz(H_EMA_SB);
   int EMA_PAD   = sz(H_EMA_PAD);
   int EMA_CARD  = EmaCardH();          // tổng chiều cao card EMA

   // Gaps
   int G_HDR_OV  = sz(GAP_HDR_OV);
   int G_LBL     = sz(GAP_SECT_LBL);
   int G_CRD_EMA = sz(GAP_CRD_EMA);
   int G_EMA_SL  = sz(GAP_EMA_SL);
   int G_SLC     = sz(GAP_SLC);
   int G_CD_BT   = sz(GAP_CD_BT);
   int G_BT_LOG  = sz(GAP_BT_LOG);
   int G_LOG_FT  = sz(GAP_LOG_FT);

   // Font sizes
   int F_HDR     = fs(10);
   int F_SECT    = fs(7);
   int F_CLBL    = fs(7);
   int F_CVAL    = fs(18);
   int F_CVAL2   = fs(14);
   int F_BODY    = fs(8);
   int F_VAL     = fs(9);
   int F_BTN     = fs(9);

   // Card width: 4 cột, gap giữa, margin 2 bên
   // Tổng: 4*CRD_W + 3*CARD_GAP + 2*MH/2 = PW_
   int cg_       = sz(CARD_GAP);
   int CRD_W     = (PW_ - MH - cg_*3) / 4;   // chia 4 đều

   // ════════════════════════════════════════════════════════════
   //  TÍNH TỔNG CHIỀU CAO (từ trên xuống, đúng thứ tự vẽ)
   //
   //  py
   //  + HDR_H              header
   //  + G_HDR_OV           gap header → Overview label
   //  + G_LBL              Overview label
   //  + CRD_H              4 cards
   //  + G_CRD_EMA          gap cards → EMA label
   //  + G_LBL              EMA label
   //  + EMA_CARD           card EMA đầy đủ
   //  + G_EMA_SL           gap EMA → SL label
   //  + G_LBL              SL label
   //  + SL_H               2 cards SL/Close
   //  + G_SLC              gap SL → countdown
   //  + CD_H               countdown bar
   //  + G_CD_BT            gap countdown → batch
   //  + BT_H               batch bar
   //  + G_BT_LOG           gap batch → log label
   //  + G_LBL              log label
   //  + InpMaxLog*RLOG_+sz(8)  log area
   //  + G_LOG_FT           gap log → footer
   //  + FT_H               footer
   // ════════════════════════════════════════════════════════════
   int totH = HDR_H + G_HDR_OV + G_LBL + CRD_H
            + G_CRD_EMA + G_LBL + EMA_CARD
            + G_EMA_SL  + G_LBL + SL_H
            + G_SLC + CD_H + G_CD_BT + BT_H
            + G_BT_LOG + G_LBL + InpMaxLog*RLOG_ + sz(8)
            + G_LOG_FT + FT_H;

   // Shadow + background
   Rect("d_sh", px+3, py+3, PW_, totH, C'6,8,14', C'6,8,14', 0);
   Rect("d_bg", px,   py,   PW_, totH, C_BG, C_BDR2, 1);

   // ════════════════════════════════════════════════════════════
   //  HEADER
   //  Layout (trái → phải):
   //  [title] | [symbol]   [status]   [S][M][L][XL]  [X]
   // ════════════════════════════════════════════════════════════
   Rect("d_hdr_bg",   px,py,       PW_,HDR_H, C_HDR,  C_BDR2, 0);
   Rect("d_hdr_line", px,py,       PW_,2,     C_GOLD, C_GOLD, 0);
   Lbl("d_hdr_title", px+MH+sz(4), py+sz(11), "Auto tracking",  C_GOLD,  F_HDR, true);
   Lbl("d_hdr_pipe",  px+sz(100),  py+sz(12), "|",              C_MUTED2,F_BODY);
   Lbl("d_hdr_sym",   px+sz(110),  py+sz(11), gSym,             C_WHITE, F_HDR, true);
   Lbl("d_hdr_status",px+PW_/2-sz(36), py+sz(11), "[RUNNING]",  C_GREEN, F_VAL, true);

   // --- Scale buttons: 4 nút [ S ][ M ][ L ][ XL ] ---
   // Đặt sát bên trái nút [ X ], mỗi nút rộng 22px (base), cao 20px, gap 3px
   int scBtnW  = sz(22);   // chiều rộng mỗi nút scale
   int scBtnH  = sz(20);   // chiều cao nút scale
   int scBtnGp = sz(3);    // gap giữa các nút
   int scBtnY  = py + (HDR_H - scBtnH) / 2;   // canh giữa theo chiều cao header
   int hideW   = sz(50);   // chiều rộng nút [ X ]
   int hideGap = sz(4);    // gap giữa nhóm scale và nút X

   // Nút [ X ] — giữ nguyên, chỉ tính lại X để nhường chỗ scale buttons
   int hideX = px + PW_ - hideW - sz(4);
   Btn("d_btn_hide", hideX, scBtnY, hideW, scBtnH, "[ X ]", C_CARD, C_CYAN, F_BTN);

   // Nhóm 4 nút scale — nằm sát bên trái nút X
   // Thứ tự phải → trái: XL, L, M, S
   string scIds[4]   = {"d_btn_sc_xl","d_btn_sc_l","d_btn_sc_m","d_btn_sc_s"};
   string scLabels[4]= {"XL","L","M","S"};
   int    scVals[4]  = {150,120,100,80};

   for(int i=0;i<4;i++)
   {
      int bx = hideX - hideGap - (i+1)*(scBtnW+scBtnGp) + scBtnGp;
      // Nút active (scale hiện tại) highlight vàng
      bool isActive = (scVals[i] == gDashScale);
      color btnBg  = isActive ? C'30,38,56' : C_CARD;
      color btnClr = isActive ? C_GOLD      : C_MUTED;
      Btn(scIds[i], bx, scBtnY, scBtnW, scBtnH, scLabels[i], btnBg, btnClr, F_BTN);
      // Active indicator: đường vàng dưới nút
      if(isActive)
         Rect(scIds[i]+"_act", bx, scBtnY+scBtnH-2, scBtnW, 2, C_GOLD, C_GOLD, 0);
   }

   // Label nhỏ "SIZE" phía bên trái nhóm nút
   int scLblX = hideX - hideGap - 4*(scBtnW+scBtnGp) + scBtnGp - sz(26);
   Lbl("d_hdr_sizelbl", scLblX, py+sz(12), "SIZE:", C_MUTED2, F_BODY);

   // ════════════════════════════════════════════════════════════
   //  SECTION A: 4 METRIC CARDS
   // ════════════════════════════════════════════════════════════
   int ay  = py + HDR_H + G_HDR_OV;    // Y label "OVERVIEW"
   int cy_ = ay + G_LBL;               // Y bắt đầu 4 card

   color cardAccent[4] = {C_BLUE, C_GREEN, C_CYAN, C_PURPLE};
   string cardId[4]    = {"c1","c2","c3","c4"};
   string cardLbl[4]   = {"POSITIONS","TOTAL P&L","SL SET","BREAKEVEN"};
   string cardVal[4]   = {"0","+0.00","0","0"};
   string cardSub[4]   = {"lenh mo","USD","lenh OK","locked"};
   color  cardVc[4]    = {C_WHITE, C_GREEN, C_CYAN, C_PURPLE};
   int    cardFs[4]    = {F_CVAL, F_CVAL2, F_CVAL, F_CVAL};

   Lbl("d_s_ov", px+MH+sz(2), ay, "OVERVIEW", C_MUTED, F_SECT);

   for(int i=0;i<4;i++)
   {
      int cx_i = px + MH/2 + (CRD_W + cg_)*i;
      Rect("d_"+cardId[i],    cx_i, cy_, CRD_W, CRD_H, C_CARD,        C_BDR);
      Rect("d_"+cardId[i]+"t",cx_i, cy_, CRD_W, 2,     cardAccent[i], cardAccent[i],0);
      Lbl("d_"+cardId[i]+"l", cx_i+sz(6), cy_+sz(9),        cardLbl[i], C_MUTED,   F_CLBL);
      Lbl("d_"+cardId[i]+"v", cx_i+sz(6), cy_+sz(21),       cardVal[i], cardVc[i], cardFs[i], true);
      Lbl("d_"+cardId[i]+"s", cx_i+sz(6), cy_+CRD_H-sz(12), cardSub[i], C_MUTED,  F_CLBL);
   }

   // ════════════════════════════════════════════════════════════
   //  SECTION B: EMA CHART CARD
   //  Lưu ý: các Y ở đây PHẢI khớp với CalcCanvasScreenY()
   // ════════════════════════════════════════════════════════════
   int by  = cy_ + CRD_H + G_CRD_EMA;  // Y label "EMA ANALYSIS"
   int eby = by  + G_LBL;              // Y outer card EMA

   Lbl("d_s_ema", px+MH+sz(2), by,
       StringFormat("EMA ANALYSIS  —  M5  ( %d / %d / %d )",gEmaFast,gEmaMid,gEmaSlow),
       C_MUTED, F_SECT);

   // Outer card
   int ema_inner_w = PW_ - MH;           // PW_ - 2*MH/2 (trái+phải)
   Rect("d_ema_bg",  px+MH/2, eby, ema_inner_w, EMA_CARD, C_CARD, C_BDR);
   Rect("d_ema_top", px+MH/2, eby, ema_inner_w, EMA_ACC,  C_GOLD2,C_GOLD2,0);

   // Sub-header
   int esh_y = eby + EMA_ACC;
   Rect("d_ema_sh", px+MH/2, esh_y, ema_inner_w, EMA_SH, C_CARD2, C_BDR, 0);
   Lbl("d_ema_shl", px+MH+sz(4), esh_y+sz(8),
       StringFormat("M5  %d / %d / %d",gEmaFast,gEmaMid,gEmaSlow), C_MUTED, F_BODY);

   // Legend dots
   int ldx = px + sz(115);
   Rect("d_leg_f", ldx,        esh_y+sz(9), sz(6),sz(6), C_YELLOW,C_YELLOW,0);
   Rect("d_leg_m", ldx+sz(22), esh_y+sz(9), sz(6),sz(6), C_CYAN,  C_CYAN,  0);
   Rect("d_leg_s", ldx+sz(44), esh_y+sz(9), sz(6),sz(6), C_ORANGE,C_ORANGE,0);
   Lbl("d_leg_fl",  ldx+sz(8),  esh_y+sz(8), "F", C_YELLOW,F_BODY,true);
   Lbl("d_leg_ml",  ldx+sz(30), esh_y+sz(8), "M", C_CYAN,  F_BODY,true);
   Lbl("d_leg_sl",  ldx+sz(52), esh_y+sz(8), "S", C_ORANGE,F_BODY,true);

   // Trend badge — căn phải, cách mép sz(12)
   Lbl("d_ema_shbdg", px+PW_-sz(120), esh_y+sz(8), "ANALYZING...", C_ORANGE, F_VAL, true);

   // Viền canvas: đặt tại cùng X, Y với InitCanvas, +1px mỗi bên
   int ecv_y = esh_y + EMA_SH;   // ← đây là ecv_y, khớp CalcCanvasScreenY()
   int cvBrdX = px + sz(MARGIN_H) - 1;
   int cvBrdW = CanvasW() + 2;
   Rect("d_ema_cvbrd", cvBrdX, ecv_y, cvBrdW, EMA_CV+2, C'5,9,17', C_BDR2, 1);

   // Controls +/- EMA periods
   int cty = ecv_y + EMA_CV + sz(4);
   Rect("d_ema_ctrl", px+MH/2, cty, ema_inner_w, EMA_CTRL, C_CARD2, C_BDR, 0);

   // 3 groups chia đều trong ema_inner_w trừ vùng SCORE sz(90) bên phải
   int scoreW   = sz(90);
   int grpsW    = ema_inner_w - scoreW;
   int grpW     = grpsW / 3;
   string grpId[3]  = {"f","m","s"};
   color  grpClr[3] = {C_YELLOW, C_CYAN, C_ORANGE};
   int    grpVal[3] = {gEmaFast, gEmaMid, gEmaSlow};
   string grpLbl[3] = {"F:","M:","S:"};

   int btnW = sz(17), btnH = sz(16);
   for(int i=0;i<3;i++)
   {
      int gx = px + MH/2 + sz(6) + grpW*i;
      int gvy = cty + (EMA_CTRL - btnH) / 2;  // vertically centred in ctrl bar

      Rect("d_ema_"+grpId[i]+"_dot", gx,       cty+sz(9), sz(7),sz(7),   grpClr[i],grpClr[i],0);
      Lbl("d_ema_"+grpId[i]+"l2",    gx+sz(10), cty+sz(6), grpLbl[i],    C_MUTED,  F_BODY);
      Lbl("d_ema_"+grpId[i]+"val",   gx+sz(28), cty+sz(5), (string)grpVal[i], grpClr[i], F_VAL, true);
      Btn("d_btn_"+grpId[i]+"_dec",  gx+sz(58), gvy,       btnW,btnH, "-", C_CARD, C_RED,   F_BTN);
      Btn("d_btn_"+grpId[i]+"_inc",  gx+sz(78), gvy,       btnW,btnH, "+", C_CARD, C_GREEN, F_BTN);
   }

   // SCORE — căn phải trong ctrl bar
   int scX = px + MH/2 + ema_inner_w - scoreW + sz(4);
   Lbl("d_ema_sc_l",    scX,        cty+sz(6), "SCORE:", C_MUTED,  F_BODY);
   Lbl("d_ema_score_v", scX+sz(46), cty+sz(5), "50",     C_ORANGE, F_VAL, true);

   // Signal row
   int sry = cty + EMA_CTRL + sz(4);
   Rect("d_ema_sig_bg", px+MH/2, sry, ema_inner_w, EMA_SIG, C_CARD2, C_BDR, 0);

   // 3 cột đều trong ema_inner_w
   int sigColW = ema_inner_w / 3;
   int col0    = px + MH/2 + sz(6);
   int col1    = px + MH/2 + sigColW;
   int col2    = px + MH/2 + sigColW*2;

   Lbl("d_ema_trl",  col0,        sry+sz(5), "TREND:",    C_MUTED,  F_BODY);
   Lbl("d_ema_trv",  col0+sz(54), sry+sz(4), "---",       C_ORANGE, F_VAL,  true);

   Rect("d_sig_s1",  col1-sz(6),  sry+sz(4), 1,sz(14),   C_MUTED2, C_MUTED2, 0);
   Lbl("d_ema_sgl",  col1+sz(4),  sry+sz(5), "SIGNAL:",   C_MUTED,  F_BODY);
   Lbl("d_ema_sgv",  col1+sz(62), sry+sz(4), "WAIT",      C_ORANGE, F_VAL,  true);

   Rect("d_sig_s2",  col2-sz(6),  sry+sz(4), 1,sz(14),   C_MUTED2, C_MUTED2, 0);
   Lbl("d_ema_stl",  col2+sz(4),  sry+sz(5), "STRENGTH:", C_MUTED,  F_BODY);
   Lbl("d_ema_stv",  col2+sz(78), sry+sz(4), "---",       C_MUTED,  F_VAL,  true);

   // Reason line
   int rsy = sry + EMA_SIG;
   Lbl("d_ema_rsn", px+MH+sz(4), rsy+sz(2), "...", C_MUTED, F_BODY);

   // Score bar — sát đáy card EMA
   int sbY = eby + EMA_CARD - EMA_SB - sz(2);
   Rect("d_sbar_bg",   px+MH/2, sbY, ema_inner_w, EMA_SB, C_CARD2,C_CARD2, 0);
   Rect("d_sbar_fill", px+MH/2, sbY, 0,           EMA_SB, C_GREEN,C_GREEN, 0);

   // ════════════════════════════════════════════════════════════
   //  SECTION C: STOP LOSS  &  AUTO CLOSE
   // ════════════════════════════════════════════════════════════
   int ccY  = eby + EMA_CARD + G_EMA_SL;   // Y label section
   int ccyy = ccY + G_LBL;                 // Y bắt đầu 2 card

   // Chia 2 card đều, cùng gap ở giữa như cg_
   int hw  = (PW_ - MH - cg_) / 2;

   Lbl("d_s_sl", px+MH+sz(2), ccY, "STOP LOSS  &  CLOSE", C_MUTED, F_SECT);

   // Card SL (trái)
   int slX = px + MH/2;
   Rect("d_sl_c", slX, ccyy, hw, SL_H, C_CARD, C_BDR);
   Rect("d_sl_t", slX, ccyy, hw, 2,    C_CYAN, C_CYAN, 0);
   Lbl("d_sl_hd", slX+sz(6), ccyy+sz(9),            "STOP LOSS H1",   C_CYAN,  F_VAL,  true);
   Lbl("d_sl_bl", slX+sz(6), ccyy+SL_H*28/100,      "BUY SL:",        C_MUTED, F_BODY);
   Lbl("d_sl_bv", slX+sz(6)+sz(68), ccyy+SL_H*28/100,"---",           C_BLUE,  F_VAL,  true);
   Lbl("d_sl_sl", slX+sz(6), ccyy+SL_H*50/100,      "SELL SL:",       C_MUTED, F_BODY);
   Lbl("d_sl_sv", slX+sz(6)+sz(68), ccyy+SL_H*50/100,"---",           C_RED,   F_VAL,  true);
   Lbl("d_sl_st", slX+sz(6), ccyy+SL_H*72/100,      "0 OK / 0 FAIL",  C_GREEN, F_BODY);
   Lbl("d_sl_rt", slX+sz(6), ccyy+SL_H*86/100,      "",               C_MUTED, F_BODY);

   // Card AutoClose (phải)
   int clx = slX + hw + cg_;
   Rect("d_cl_c", clx, ccyy, hw, SL_H, C_CARD, C_BDR);
   Rect("d_cl_t", clx, ccyy, hw, 2,    C_YELLOW, C_YELLOW, 0);
   Lbl("d_cl_hd", clx+sz(6), ccyy+sz(9),           "AUTO CLOSE",     C_YELLOW,F_VAL,  true);
   Lbl("d_cl_ml", clx+sz(6), ccyy+SL_H*28/100,     "Phut dong:",     C_MUTED, F_BODY);
   Lbl("d_cl_mv", clx+sz(6)+sz(80), ccyy+SL_H*28/100,
       InpAutoClose?StringFormat(":%02d",InpCloseMinute):"OFF",
       InpAutoClose?C_YELLOW:C_MUTED, F_VAL, true);
   Lbl("d_cl_cdl",clx+sz(6), ccyy+SL_H*50/100,     "Countdown:",     C_MUTED, F_BODY);
   Lbl("d_cl_cdv",clx+sz(6)+sz(80),ccyy+SL_H*50/100,"--",            C_CYAN,  F_VAL,  true);
   Lbl("d_cl_st", clx+sz(6), ccyy+SL_H*72/100,     "0 OK / 0 FAIL",  C_GREEN, F_BODY);
   Lbl("d_cl_be", clx+sz(6), ccyy+SL_H*86/100,
       InpBEEnabled?StringFormat("BE: $%.0f >> +$%.0f",InpBETrigger,InpBELock):"BE: OFF",
       InpBEEnabled?C_PURPLE:C_MUTED, F_BODY);

   // ════════════════════════════════════════════════════════════
   //  SECTION D: COUNTDOWN BAR
   // ════════════════════════════════════════════════════════════
   int dy = ccyy + SL_H + G_SLC;

   // Progress bar: bắt đầu sau label "CLOSE TIMER:", kết thúc cách mép phải sz(6)
   int cdLblW   = sz(105);                          // ước lượng chiều rộng chữ label
   int cdbarX   = px + MH/2 + cdLblW;
   int cdbarW   = PW_ - MH - cdLblW - sz(6);       // tự scale: không hardcode
   int cdbarH   = sz(8);
   int cdbarY   = dy + (CD_H - cdbarH) / 2;

   Rect("d_cd_c",    px+MH/2, dy,     PW_-MH,  CD_H, C_CARD2,C_BDR);
   Lbl("d_cd_lbl",   px+MH+sz(4), dy+sz(6), "CLOSE TIMER:", C_MUTED, F_BODY);
   Rect("d_cd_bg",   cdbarX, cdbarY, cdbarW,  cdbarH, C'14,20,34',C_BDR);
   Rect("d_cd_fill", cdbarX, cdbarY, 0,       cdbarH, C_GREEN,C_GREEN,0);
   Lbl("d_cd_txt",   cdbarX+sz(4), dy+sz(6), "-- phut nua", C_WHITE, F_BODY, true);

   // ════════════════════════════════════════════════════════════
   //  SECTION E: BATCH STATUS BAR
   // ════════════════════════════════════════════════════════════
   int ey = dy + CD_H + G_CD_BT;
   Rect("d_bt_bg", px+MH/2, ey, PW_-MH, BT_H, C_CARD2,C_BDR);
   Lbl("d_bt_l",   px+MH+sz(4), ey+sz(5), "BATCH:",    C_MUTED, F_BODY);
   Lbl("d_bt_v",   px+MH+sz(50),ey+sz(5), "STANDBY",   C_GREEN, F_BODY, true);

   // Separator + BE info: không hardcode số tuyệt đối, dùng PW_ fraction
   int sep1x = px + MH/2 + PW_/4;
   int sep2x = px + MH/2 + PW_*3/4;
   Lbl("d_bt_s1", sep1x,       ey+sz(5), "|",         C_MUTED2,F_BODY);
   Lbl("d_bt_be", sep1x+sz(8), ey+sz(5),
       InpBEEnabled?StringFormat("BE $%.0f>>+$%.0f",InpBETrigger,InpBELock):"BE:OFF",
       InpBEEnabled?C_PURPLE:C_MUTED, F_BODY);
   Lbl("d_bt_s2", sep2x,        ey+sz(5), "|",         C_MUTED2,F_BODY);
   Lbl("d_bt_rt", sep2x+sz(8),  ey+sz(5),
       StringFormat("Retry %dx%dms | Delay %dms",InpRetryCount,InpRetryDelay,InpBatchDelay),
       C_MUTED, F_BODY);

   // ════════════════════════════════════════════════════════════
   //  SECTION F: LOG
   // ════════════════════════════════════════════════════════════
   int fy  = ey + BT_H + G_BT_LOG;
   int lgy = fy + G_LBL;
   Lbl("d_log_l",  px+MH+sz(2), fy, "JOURNAL", C_MUTED, F_SECT);
   Rect("d_log_bg",px+MH/2, lgy, PW_-MH, InpMaxLog*RLOG_+sz(8), C'8,12,20',C_BDR);
   for(int i=0;i<InpMaxLog;i++)
      Lbl(StringFormat("d_log%d",i), px+MH+sz(4), lgy+sz(4)+i*RLOG_, "", C_MUTED, F_BODY);

   // ════════════════════════════════════════════════════════════
   //  FOOTER
   // ════════════════════════════════════════════════════════════
   int ffY = lgy + InpMaxLog*RLOG_ + sz(8) + G_LOG_FT;
   Rect("d_ft_bg",  px,ffY, PW_,FT_H, C'10,13,20',C_BDR, 0);
   Rect("d_ft_line",px,ffY, PW_,1,    C_GOLD2,C_GOLD2, 0);
   Lbl("d_ft_sym",  px+MH+sz(4), ffY+sz(4), gSym,                         C_GOLD,  F_BODY, true);
   Lbl("d_ft_s1",   px+sz(50),   ffY+sz(4), "|",                           C_MUTED2,F_BODY);
   Lbl("d_ft_time", px+sz(58),   ffY+sz(4), "",                            C_MUTED, F_BODY);
   Lbl("d_ft_s2",   px+PW_-sz(200),ffY+sz(4), "|",                         C_MUTED2,F_BODY);
   Lbl("d_ft_srv",  px+PW_-sz(192),ffY+sz(4), "copyright by TVH-SMILE",    C_MUTED, F_BODY);

   ChartRedraw(0);
}

//======================================================================
//  PANEL TOGGLE
//======================================================================
void PanelToggle()
{
   // Các object trong header luôn hiển thị (kể cả khi hidden)
   // Tất cả object khác toggle theo gHidden
   for(int i=0;i<ArraySize(gObjs);i++)
   {
      string n=gObjs[i];
      // Giữ lại: background, toàn bộ header, các nút scale, nút hide
      if(n=="d_bg"||n=="d_sh"
         ||n=="d_hdr_bg"||n=="d_hdr_line"
         ||n=="d_hdr_title"||n=="d_hdr_pipe"||n=="d_hdr_sym"
         ||n=="d_hdr_ver"||n=="d_hdr_status"||n=="d_hdr_clock"
         ||n=="d_hdr_sizelbl"
         ||n=="d_btn_hide"||n=="d_btn_hide_bg"
         // Nút scale + active indicator
         ||n=="d_btn_sc_s"  ||n=="d_btn_sc_s_bg"  ||n=="d_btn_sc_s_act"
         ||n=="d_btn_sc_m"  ||n=="d_btn_sc_m_bg"  ||n=="d_btn_sc_m_act"
         ||n=="d_btn_sc_l"  ||n=="d_btn_sc_l_bg"  ||n=="d_btn_sc_l_act"
         ||n=="d_btn_sc_xl" ||n=="d_btn_sc_xl_bg" ||n=="d_btn_sc_xl_act"
      ) continue;
      ObjVis(n,!gHidden);
   }
}

//======================================================================
//  PANEL UPDATE
//======================================================================
void PanelUpdate()
{
   MqlDateTime dt; TimeToStruct(TimeCurrent(),dt);
   ObjTxt("d_hdr_clock",TimeToString(TimeCurrent(),TIME_SECONDS));

   if(gHidden){ ChartRedraw(0); return; }

   int    PW_     = sz(PW_BASE);
   int    MH      = sz(MARGIN_H);
   int    cg_     = sz(CARD_GAP);

   double h1h=H1High(), h1l=H1Low();
   double pt=SymbolInfoDouble(gSym,SYMBOL_POINT);
   int    dg=(int)SymbolInfoInteger(gSym,SYMBOL_DIGITS);
   double slS=NormalizeDouble(h1h+InpExtraPoints*pt,dg);
   double slB=NormalizeDouble(h1l-InpExtraPoints*pt,dg);
   int    pc=CntPos();
   double pnl=TotPnL();
   int    ml=MnLeft();
   bool   isClose=(dt.min==InpCloseMinute&&InpAutoClose);
   bool   isWarn =(ml<=InpCloseWarning&&ml>0&&InpAutoClose);

   if(gBatchRunning)   { ObjTxt("d_hdr_status","[BUSY]");    ObjClr("d_hdr_status",C_ORANGE); }
   else if(isClose)    { ObjTxt("d_hdr_status","[CLOSING]"); ObjClr("d_hdr_status",C_RED);    }
   else                { ObjTxt("d_hdr_status","[RUNNING]"); ObjClr("d_hdr_status",C_GREEN);  }

   // Cập nhật highlight nút scale theo gDashScale hiện tại
   string scIds2[4]  = {"d_btn_sc_s","d_btn_sc_m","d_btn_sc_l","d_btn_sc_xl"};
   int    scVals2[4] = {80,100,120,150};
   for(int i=0;i<4;i++)
   {
      bool active = (scVals2[i] == gDashScale);
      ObjClr(scIds2[i], active ? C_GOLD : C_MUTED);
      ObjectSetInteger(0, scIds2[i]+"_bg", OBJPROP_BGCOLOR, active ? C'30,38,56' : C_CARD);
   }

   // Metric cards
   ObjTxt("d_c1v",(string)pc);  ObjClr("d_c1v",pc>0?C_WHITE:C_MUTED);  ObjTxt("d_c1s",pc>0?"lenh mo":"trong");
   string ps=(pnl>=0?"+":"")+DoubleToString(pnl,2);
   ObjTxt("d_c2v",ps); ObjClr("d_c2v",pnl>0?C_GREEN:pnl<0?C_RED:C_MUTED);
   ObjectSetInteger(0,"d_c2t",OBJPROP_BGCOLOR,pnl>0?C_GREEN:pnl<0?C_RED:C_BDR);
   ObjectSetInteger(0,"d_c2t",OBJPROP_COLOR,  pnl>0?C_GREEN:pnl<0?C_RED:C_BDR);
   ObjTxt("d_c3v",(string)statSLOk);
   ObjTxt("d_c4v",(string)statBEOk); ObjClr("d_c4v",statBEOk>0?C_PURPLE:C_MUTED);

   // EMA signal
   EmaSnap ema; Signal sig;
   if(GetEMA(ema))
   {
      sig=Analyze(ema);
      ObjTxt("d_ema_shbdg",sig.trend); ObjClr("d_ema_shbdg",sig.tc);
      ObjTxt("d_ema_trv",sig.trend);   ObjClr("d_ema_trv",sig.tc);
      ObjTxt("d_ema_sgv",sig.sig);     ObjClr("d_ema_sgv",sig.sc);
      ObjTxt("d_ema_stv",sig.str);
      ObjClr("d_ema_stv",sig.str=="MANH"?C_GREEN:sig.str=="TRUNG BINH"?C_YELLOW:C_ORANGE);
      ObjTxt("d_ema_rsn",sig.reason);
      ObjTxt("d_ema_score_v",(string)sig.score); ObjClr("d_ema_score_v",sig.tc);

      // Score bar — chiều rộng tỉ lệ theo ema_inner_w
      int ema_inner_w = PW_ - MH;
      ObjW("d_sbar_fill",(int)(ema_inner_w * sig.score / 100.0));
      ObjBg("d_sbar_fill",sig.tc);
   }

   // SL card
   ObjTxt("d_sl_bv",DoubleToString(slB,2));
   ObjTxt("d_sl_sv",DoubleToString(slS,2));
   int slt=statSLOk+statSLFail;
   ObjTxt("d_sl_st",StringFormat("%d OK / %d FAIL (%d%%)",statSLOk,statSLFail,slt>0?(int)(statSLOk*100.0/slt):0));
   ObjClr("d_sl_st",statSLFail>0?C_ORANGE:C_GREEN);
   ObjTxt("d_sl_rt",StringFormat("Buffer: %.0f pts",InpExtraPoints));

   // Close card
   string cds; color cdc;
   if(isClose)    { cds="DONG NGAY!";                      cdc=C_RED;    }
   else if(isWarn){ cds=StringFormat("!! %d PHUT !!",ml);  cdc=C_ORANGE; }
   else           { cds=StringFormat("%d phut nua",ml);     cdc=C_CYAN;   }
   ObjTxt("d_cl_cdv",cds); ObjClr("d_cl_cdv",cdc);
   ObjTxt("d_cl_st",StringFormat("%d OK / %d FAIL",statClOk,statClFail));
   ObjClr("d_cl_st",statClFail>0?C_ORANGE:C_GREEN);

   // Countdown bar — cdbarW phải tính giống BuildPanel
   int cdLblW  = sz(105);
   int cdbarW  = PW_ - MH - cdLblW - sz(6);
   ObjW("d_cd_fill", MathMax(0, MathMin((int)(cdbarW*(1.0-ml/60.0)), cdbarW)));
   color bc = isClose?C_RED:isWarn?C_ORANGE:C_GREEN;
   ObjBg("d_cd_fill",bc);
   int s2c=ml*60-dt.sec; if(s2c<0)s2c=0;
   ObjTxt("d_cd_txt",StringFormat("%02d:%02d den phut :%02d",s2c/60,s2c%60,InpCloseMinute));
   ObjClr("d_cd_txt",bc);

   // Batch bar
   if(gBatchRunning)      { ObjTxt("d_bt_v","PROCESSING..."); ObjClr("d_bt_v",C_ORANGE); }
   else if(isClose&&pc>0) { ObjTxt("d_bt_v","CLOSING ALL");   ObjClr("d_bt_v",C_RED);    }
   else if(isWarn&&pc>0)  { ObjTxt("d_bt_v",StringFormat("WARN -%dmin",ml)); ObjClr("d_bt_v",C_ORANGE); }
   else                   { ObjTxt("d_bt_v","STANDBY");        ObjClr("d_bt_v",C_GREEN);  }

   // Log
   int lsz=ArraySize(gLog);
   for(int i=0;i<InpMaxLog;i++)
   {
      int idx=lsz-InpMaxLog+i;
      if(idx<0||idx>=lsz){ ObjTxt(StringFormat("d_log%d",i),""); continue; }
      string raw=gLog[idx];
      int pipe=StringFind(raw,"|",StringLen(raw)-5);
      string txt=pipe>=0?StringSubstr(raw,0,pipe):raw;
      string typ=pipe>=0?StringSubstr(raw,pipe+1):"info";
      color lc=(typ=="ok")?C_GREEN:(typ=="err")?C_RED:(typ=="warn")?C_ORANGE:C_MUTED;
      ObjTxt(StringFormat("d_log%d",i),txt);
      ObjClr(StringFormat("d_log%d",i),lc);
   }

   ObjTxt("d_ft_time",TimeToString(TimeCurrent(),TIME_DATE|TIME_SECONDS));
   ChartRedraw(0);
}
