double H1High() { double a[]; ArraySetAsSeries(a,true); if(CopyHigh(gSym,PERIOD_H1,0,1,a)<1) return 0; return a[0]; }
double H1Low()  { double a[]; ArraySetAsSeries(a,true); if(CopyLow( gSym,PERIOD_H1,0,1,a)<1) return 0; return a[0]; }
int    CntPos() { int c=0; for(int i=0;i<PositionsTotal();i++) if(posInfo.SelectByIndex(i)&&posInfo.Symbol()==gSym) c++; return c; }
int    MnLeft() { MqlDateTime d; TimeToStruct(TimeCurrent(),d); int v=InpCloseMinute-d.min; if(v<0)v+=60; return v; }
double TotPnL() { double p=0; for(int i=0;i<PositionsTotal();i++) if(posInfo.SelectByIndex(i)&&posInfo.Symbol()==gSym) p+=posInfo.Profit()+posInfo.Swap()+posInfo.Commission(); return p; }
double USD2Pt(double usd,double lot){ if(lot<=0)return 0; double tv=SymbolInfoDouble(gSym,SYMBOL_TRADE_TICK_VALUE),ts=SymbolInfoDouble(gSym,SYMBOL_TRADE_TICK_SIZE); if(tv<=0||ts<=0)return 0; return usd*ts/(tv*lot); }

bool InSL(ulong t){ for(int i=0;i<ArraySize(tickSL);i++) if(tickSL[i]==t) return true; return false; }
bool InBE(ulong t){ for(int i=0;i<ArraySize(tickBE);i++) if(tickBE[i]==t) return true; return false; }
void AddSL(ulong t){ if(InSL(t))return; int s=ArraySize(tickSL); ArrayResize(tickSL,s+1); tickSL[s]=t; }
void AddBE(ulong t){ if(InBE(t))return; int s=ArraySize(tickBE); ArrayResize(tickBE,s+1); tickBE[s]=t; }
void AddCL(ulong t){ int s=ArraySize(tickCL); ArrayResize(tickCL,s+1); tickCL[s]=t; }

void CleanTicks()
{
   ulong a[]; int c=0;
   for(int i=0;i<ArraySize(tickSL);i++) if(PositionSelectByTicket(tickSL[i])){ ArrayResize(a,c+1); a[c++]=tickSL[i]; }
   ArrayResize(tickSL,c); for(int i=0;i<c;i++) tickSL[i]=a[i];
   ulong b[]; int bc=0;
   for(int i=0;i<ArraySize(tickBE);i++) if(PositionSelectByTicket(tickBE[i])){ ArrayResize(b,bc+1); b[bc++]=tickBE[i]; }
   ArrayResize(tickBE,bc); for(int i=0;i<bc;i++) tickBE[i]=b[i];
}

bool ModRetry(ulong tk,double sl,double tp)
{
   for(int a=1;a<=InpRetryCount;a++)
   {
      if(trade.PositionModify(tk,sl,tp)) return true;
      uint rc=trade.ResultRetcode();
      if(rc==TRADE_RETCODE_INVALID_STOPS||rc==TRADE_RETCODE_TRADE_DISABLED||rc==TRADE_RETCODE_MARKET_CLOSED) return false;
      if(a<InpRetryCount) Sleep(InpRetryDelay);
   }
   return false;
}
bool ClsRetry(ulong tk)
{
   for(int a=1;a<=InpRetryCount;a++)
   {
      if(trade.PositionClose(tk,ULONG_MAX)) return true;
      if(!PositionSelectByTicket(tk)) return true;
      uint rc=trade.ResultRetcode();
      if(rc==TRADE_RETCODE_TRADE_DISABLED||rc==TRADE_RETCODE_MARKET_CLOSED) return false;
      if(a<InpRetryCount) Sleep(InpRetryDelay);
   }
   return false;
}

//======================================================================
//  CORE LOGIC
//======================================================================
void DoSetSL()
{
   double h1h=H1High(); if(h1h<=0) return;
   double h1l=H1Low();  if(h1l<=0) return;
   double pt=SymbolInfoDouble(gSym,SYMBOL_POINT);
   int    dg=(int)SymbolInfoInteger(gSym,SYMBOL_DIGITS);
   double slS=NormalizeDouble(h1h+InpExtraPoints*pt,dg);
   double slB=NormalizeDouble(h1l-InpExtraPoints*pt,dg);

   ulong need[]; int nc=0;
   for(int i=PositionsTotal()-1;i>=0;i--)
   {
      if(!posInfo.SelectByIndex(i)||posInfo.Symbol()!=gSym) continue;
      int tp=(int)posInfo.PositionType(); ulong tk=posInfo.Ticket(); double cs=posInfo.StopLoss();
      if(InpOnlyBuy&&tp!=POSITION_TYPE_BUY) continue;
      if(InpOnlySell&&tp!=POSITION_TYPE_SELL) continue;
      double tSL=(tp==POSITION_TYPE_BUY)?slB:slS;
      bool done=InSL(tk);
      if(cs!=0&&!InpOverwriteSL&&done) continue;
      if(MathAbs(cs-tSL)<pt*0.5&&done) continue;
      if(InBE(tk)){ if(tp==POSITION_TYPE_BUY&&cs>=tSL) continue; if(tp==POSITION_TYPE_SELL&&cs<=tSL) continue; }
      ArrayResize(need,nc+1); need[nc++]=tk;
   }
   if(nc==0){ CleanTicks(); return; }

   gBatchRunning=true;
   int ok=0,fail=0;
   for(int i=0;i<nc;i++)
   {
      if(!PositionSelectByTicket(need[i])) continue;
      int tp=(int)PositionGetInteger(POSITION_TYPE);
      double tSL=(tp==POSITION_TYPE_BUY)?slB:slS;
      double tp2=PositionGetDouble(POSITION_TP);
      if(ModRetry(need[i],tSL,tp2)){ ok++; statSLOk++; AddSL(need[i]); }
      else{ fail++; statSLFail++; Log(StringFormat("FAIL SL #%I64u",need[i]),"err"); }
      if(i<nc-1&&InpBatchDelay>0) Sleep(InpBatchDelay);
   }
   gBatchRunning=false;
   Log(StringFormat("SL: %d OK / %d FAIL | BUY=%.2f SELL=%.2f",ok,fail,slB,slS),ok>0?"ok":"err");
   if(InpAlertOnSet&&ok>0) Alert(StringFormat("[AutoSL] %d lenh | BUY SL=%.2f | SELL SL=%.2f",ok,slB,slS));
   CleanTicks();
}

void DoBreakeven()
{
   int dg=(int)SymbolInfoInteger(gSym,SYMBOL_DIGITS);
   for(int i=PositionsTotal()-1;i>=0;i--)
   {
      if(!posInfo.SelectByIndex(i)||posInfo.Symbol()!=gSym) continue;
      int tp=(int)posInfo.PositionType(); ulong tk=posInfo.Ticket();
      double lot=posInfo.Volume(),entry=posInfo.PriceOpen(),cSL=posInfo.StopLoss(),cTP=posInfo.TakeProfit();
      double pnl=posInfo.Profit()+posInfo.Swap()+posInfo.Commission();
      if((InpOnlyBuy&&tp!=POSITION_TYPE_BUY)||(InpOnlySell&&tp!=POSITION_TYPE_SELL)) continue;
      if(InBE(tk)||pnl<InpBETrigger) continue;
      double off=USD2Pt(InpBELock,lot); if(off<=0) continue;
      double newSL=0;
      if(tp==POSITION_TYPE_BUY){ newSL=NormalizeDouble(entry+off,dg); if(cSL>=newSL) continue; }
      else                     { newSL=NormalizeDouble(entry-off,dg); if(cSL>0&&cSL<=newSL) continue; }
      if(ModRetry(tk,newSL,cTP))
      {
         statBEOk++; AddBE(tk);
         string dir=(tp==POSITION_TYPE_BUY)?"BUY":"SELL";
         Log(StringFormat("BE+ #%I64u %s $%.2f >> SL=%.2f (+$%.2f)",tk,dir,pnl,newSL,InpBELock),"ok");
         Alert(StringFormat("[BE+] #%I64u %s | Lai=$%.2f | SL=%.2f | Lock +$%.2f",tk,dir,pnl,newSL,InpBELock));
      }
   }
}

void DoAutoClose()
{
   MqlDateTime dt; TimeToStruct(TimeCurrent(),dt); int cm=dt.min;
   if(gCloseTrig&&cm!=InpCloseMinute) gCloseTrig=false;
   int ml=InpCloseMinute-cm; if(ml<0)ml+=60;
   if(ml>0&&ml<=InpCloseWarning&&gLastWarnMn!=cm)
   { int cnt=CntPos(); if(cnt>0){ Log(StringFormat("CANH BAO: %d phut | %d lenh",ml,cnt),"warn"); gLastWarnMn=cm; } }
   if(cm!=InpCloseMinute||gCloseTrig) return;

   ulong tc[]; int tcc=0;
   for(int i=PositionsTotal()-1;i>=0;i--)
   {
      if(!posInfo.SelectByIndex(i)||posInfo.Symbol()!=gSym) continue;
      int tp=(int)posInfo.PositionType();
      if((InpOnlyBuy&&tp!=POSITION_TYPE_BUY)||(InpOnlySell&&tp!=POSITION_TYPE_SELL)) continue;
      ArrayResize(tc,tcc+1); tc[tcc++]=posInfo.Ticket();
   }
   if(tcc==0){ gCloseTrig=true; return; }
   gBatchRunning=true;
   Log(StringFormat("AUTO CLOSE: dong %d lenh @ phut %02d",tcc,InpCloseMinute),"warn");
   int ok=0,fail=0;
   for(int i=0;i<tcc;i++)
   {
      if(ClsRetry(tc[i])){ ok++; statClOk++; AddCL(tc[i]); }
      else{ fail++; statClFail++; }
      if(i<tcc-1&&InpBatchDelay>0) Sleep(InpBatchDelay);
   }
   gBatchRunning=false; gCloseTrig=true; gLastCloseMn=cm;
   Log(StringFormat("Close: %d OK / %d FAIL",ok,fail),ok>0?"ok":"err");
   if(InpAlertOnClose) Alert(StringFormat("[AutoClose] %d/%d lenh @ phut %02d",ok,tcc,InpCloseMinute));
}

//======================================================================
//  EMA ANALYSIS
//======================================================================
struct EmaSnap { double f,m,s,fp,mp,sp,price; };
struct Signal  { string trend,sig,str,reason; color tc,sc; int score; };

bool GetEMA(EmaSnap& e)
{
   double f[],m[],s[];
   ArraySetAsSeries(f,true); ArraySetAsSeries(m,true); ArraySetAsSeries(s,true);
   if(CopyBuffer(hFast,0,0,3,f)<3||CopyBuffer(hMid,0,0,3,m)<3||CopyBuffer(hSlow,0,0,3,s)<3) return false;
   e.f=f[0];e.fp=f[1]; e.m=m[0];e.mp=m[1]; e.s=s[0];e.sp=s[1];
   e.price=SymbolInfoDouble(gSym,SYMBOL_BID);
   return true;
}

Signal Analyze(EmaSnap& e)
{
   Signal r; r.score=50;
   bool fAboveM=e.f>e.m,fAboveS=e.f>e.s,mAboveS=e.m>e.s;
   bool pAboveF=e.price>e.f,pAboveM=e.price>e.m,pAboveS=e.price>e.s;
   bool fRising=e.f>e.fp,mRising=e.m>e.mp;
   bool golden=(e.f>e.m)&&(e.fp<=e.mp), death=(e.f<e.m)&&(e.fp>=e.mp);

   if(fAboveM)r.score+=10;else r.score-=10; if(fAboveS)r.score+=12;else r.score-=12;
   if(mAboveS)r.score+=10;else r.score-=10; if(pAboveF)r.score+=6; else r.score-=6;
   if(pAboveM)r.score+=6; else r.score-=6;  if(pAboveS)r.score+=6; else r.score-=6;
   if(fRising)r.score+=5; else r.score-=5;  if(mRising)r.score+=5; else r.score-=5;
   r.score=MathMax(0,MathMin(100,r.score));

   if(r.score>=65)     { r.trend="BULLISH";r.tc=C_GREEN;  }
   else if(r.score<=35){ r.trend="BEARISH";r.tc=C_RED;    }
   else                { r.trend="SIDEWAY";r.tc=C_ORANGE; }

   if(golden&&mAboveS)             { r.sig="BUY"; r.sc=C_GREEN; r.str="MANH";       r.reason=StringFormat("Golden Cross EMA%d/%d | Stack bullish M5",gEmaFast,gEmaMid); }
   else if(death&&!mAboveS)        { r.sig="SELL";r.sc=C_RED;   r.str="MANH";       r.reason=StringFormat("Death Cross EMA%d/%d | Stack bearish M5",gEmaFast,gEmaMid); }
   else if(r.trend=="BULLISH"&&pAboveF&&pAboveM&&fAboveS){ r.sig="BUY"; r.sc=C_GREEN; r.str="TRUNG BINH";r.reason=StringFormat("Gia > EMA%d & EMA%d | Xu huong tang M5",gEmaFast,gEmaMid); }
   else if(r.trend=="BEARISH"&&!pAboveF&&!pAboveM&&!fAboveS){ r.sig="SELL";r.sc=C_RED; r.str="TRUNG BINH";r.reason=StringFormat("Gia < EMA%d & EMA%d | Xu huong giam M5",gEmaFast,gEmaMid); }
   else if(r.trend=="BULLISH"&&!pAboveF&&pAboveM){ r.sig="BUY"; r.sc=C_YELLOW;r.str="YEU";r.reason=StringFormat("Pullback EMA%d | Cho nen xac nhan M5",gEmaFast); }
   else if(r.trend=="BEARISH"&&pAboveF&&!pAboveM){ r.sig="SELL";r.sc=C_YELLOW;r.str="YEU";r.reason=StringFormat("Pullback EMA%d | Cho nen xac nhan M5",gEmaFast); }
   else { r.sig="WAIT";r.sc=C_ORANGE;r.str="---";r.reason="EMA M5 chua xac dinh xu huong ro rang"; }
   return r;
}

//======================================================================
//  LOG
//======================================================================
void Log(string msg,string typ)
{
   MqlDateTime d; TimeToStruct(TimeCurrent(),d);
   string ts=StringFormat("%02d:%02d:%02d",d.hour,d.min,d.sec);
   string line="["+ts+"] "+msg+"|"+typ;
   int sz_=ArraySize(gLog);
   if(sz_>=InpMaxLog){ for(int i=0;i<sz_-1;i++) gLog[i]=gLog[i+1]; gLog[sz_-1]=line; }
   else{ ArrayResize(gLog,sz_+1); gLog[sz_]=line; }
   Print("[EA] "+msg);
}

