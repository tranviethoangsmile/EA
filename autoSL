// Tất cả chiều cao đều dùng sz() để scale theo DASH_SCALE
// Hàm này trả về Y tuyệt đối của vùng vẽ canvas trên màn hình
int CalcCanvasScreenY()
{
   // Chuỗi Y: panel_top → header → section label → cards → EMA label → EMA subheader → canvas
   int y = InpPanelY;
   y += sz(32);    // header height
   y += sz(38);    // khoảng cách header → label "OVERVIEW"
   y += sz(12);    // chiều cao chữ section label
   y += sz(62);    // chiều cao card metric
   y += sz(10);    // gap trước section EMA
   y += sz(13);    // chiều cao chữ label "EMA ANALYSIS"
   y += sz(2);     // top accent bar
   y += sz(22);    // sub-header height
   // Đây là Y của viền canvas → canvas nằm +1px bên trong viền
   return y;
}

//======================================================================
//  INIT / DEINIT
//======================================================================
int OnInit()
{
   gSym = (InpSymbol == "") ? Symbol() : InpSymbol;
   if(!SymbolSelect(gSym, true)){ Alert("Symbol not found: " + gSym); return INIT_FAILED; }

   trade.SetDeviationInPoints(20);
   trade.SetAsyncMode(false);

   gEmaFast = InpEMA_Fast;
   gEmaMid  = InpEMA_Mid;
   gEmaSlow = InpEMA_Slow;

   if(!ReinitEmaHandles()) return INIT_FAILED;

   Log("EA v8.0 | " + gSym + " | Scale=" + (string)DASH_SCALE + "% | EMA " + (string)gEmaFast + "/" + (string)gEmaMid + "/" + (string)gEmaSlow, "info");
   Log(StringFormat("SL buffer=%.0fpt | BE $%.0f>>+$%.0f | Close phut %02d", InpExtraPoints, InpBETrigger, InpBELock, InpCloseMinute), "info");

   BuildPanel();
   if(!InitCanvas()) Log("Canvas init failed","err");

   EventSetTimer(InpCheckInterval);
   return INIT_SUCCEEDED;
}

void OnDeinit(const int reason)
{
   EventKillTimer();
   IndicatorRelease(hFast);
   IndicatorRelease(hMid);
   IndicatorRelease(hSlow);
   if(gCanvasReady){ gEmaCanvas.Destroy(); gCanvasReady = false; }
   ObjDeleteAll();
}

//======================================================================
//  EMA HANDLES
//======================================================================
bool ReinitEmaHandles()
{
   if(hFast != INVALID_HANDLE && hFast != 0) IndicatorRelease(hFast);
   if(hMid  != INVALID_HANDLE && hMid  != 0) IndicatorRelease(hMid);
   if(hSlow != INVALID_HANDLE && hSlow != 0) IndicatorRelease(hSlow);
   hFast = iMA(gSym, PERIOD_M5, gEmaFast, 0, MODE_EMA, PRICE_CLOSE);
   hMid  = iMA(gSym, PERIOD_M5, gEmaMid,  0, MODE_EMA, PRICE_CLOSE);
   hSlow = iMA(gSym, PERIOD_M5, gEmaSlow, 0, MODE_EMA, PRICE_CLOSE);
   if(hFast==INVALID_HANDLE || hMid==INVALID_HANDLE || hSlow==INVALID_HANDLE)
   { Alert("EMA handle error"); return false; }
   return true;
}

