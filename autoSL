bool InitCanvas()
{
   if(gCanvasReady){ gEmaCanvas.Destroy(); gCanvasReady = false; }

   int cx = InpPanelX + sz(8);
   int cy = CalcCanvasScreenY();

   if(!gEmaCanvas.CreateBitmapLabel(0, 0, CANVAS_NAME, cx, cy, CANVAS_W, CANVAS_H, COLOR_FORMAT_ARGB_NORMALIZE))
      return false;

   ObjectSetInteger(0, CANVAS_NAME, OBJPROP_CORNER,     CORNER_LEFT_UPPER);
   ObjectSetInteger(0, CANVAS_NAME, OBJPROP_SELECTABLE, false);
   ObjectSetInteger(0, CANVAS_NAME, OBJPROP_BACK,       false);
   ObjectSetInteger(0, CANVAS_NAME, OBJPROP_ZORDER,     5);
   Track(CANVAS_NAME);
   gCanvasReady = true;
   DrawEmaCanvas();
   return true;
}

void DrawEmaCanvas()
{
   if(!gCanvasReady) return;

   int W = CANVAS_W, H = CANVAS_H;
   int bars = MathMax(40, sz(75));   // số nến tự scale

   double ef[], em[], es[];
   ArraySetAsSeries(ef,true); ArraySetAsSeries(em,true); ArraySetAsSeries(es,true);
   if(CopyBuffer(hFast,0,0,bars,ef)<bars) return;
   if(CopyBuffer(hMid, 0,0,bars,em)<bars) return;
   if(CopyBuffer(hSlow,0,0,bars,es)<bars) return;

   double mn=DBL_MAX, mx=-DBL_MAX;
   for(int i=0;i<bars;i++)
   {
      mn = MathMin(mn, MathMin(ef[i], MathMin(em[i], es[i])));
      mx = MathMax(mx, MathMax(ef[i], MathMax(em[i], es[i])));
   }
   double range = mx - mn;
   if(range <= 0) return;
   double pad = range * 0.10;
   mn -= pad; mx += pad; range = mx - mn;

   const int PL=4, PR=4, PT=5, PB=5;
   int cW = W - PL - PR;
   int cH = H - PT - PB;
   double barW = (double)cW / bars;

   gEmaCanvas.Erase(ColorToARGB(C'5,9,17',255));

   uint gridC = ColorToARGB(C'22,30,50',255);
   for(int g=1;g<=3;g++)
   {
      int gy = PT + g*cH/4;
      for(int x=PL; x<W-PR; x+=5)
         gEmaCanvas.PixelSet(x, gy, gridC);
   }
   for(int vb=10; vb<bars; vb+=10)
   {
      int gx = PL + (int)((bars-vb)*barW + barW*0.5);
      for(int y=PT; y<H-PB; y+=5)
         gEmaCanvas.PixelSet(gx, y, gridC);
   }

   uint cF = ColorToARGB(C_YELLOW, 230);
   uint cM = ColorToARGB(C_CYAN,   220);
   uint cS = ColorToARGB(C_ORANGE, 200);

   for(int i=bars-2; i>=0; i--)
   {
      int bi0=bars-1-(i+1), bi1=bars-1-i;
      int xa=PL+(int)(bi0*barW+barW*0.5), xb=PL+(int)(bi1*barW+barW*0.5);
      int yS0=MathMax(PT,MathMin(H-PB,PT+(int)((mx-es[i+1])/range*cH)));
      int yS1=MathMax(PT,MathMin(H-PB,PT+(int)((mx-es[i])  /range*cH)));
      int yM0=MathMax(PT,MathMin(H-PB,PT+(int)((mx-em[i+1])/range*cH)));
      int yM1=MathMax(PT,MathMin(H-PB,PT+(int)((mx-em[i])  /range*cH)));
      int yF0=MathMax(PT,MathMin(H-PB,PT+(int)((mx-ef[i+1])/range*cH)));
      int yF1=MathMax(PT,MathMin(H-PB,PT+(int)((mx-ef[i])  /range*cH)));
      gEmaCanvas.Line(xa,yS0,xb,yS1,cS);
      gEmaCanvas.Line(xa,yM0,xb,yM1,cM);
      gEmaCanvas.Line(xa,yF0,xb,yF1,cF);
   }

   for(int i=bars-2; i>=1; i--)
   {
      bool wasBelowMid=(ef[i+1]<=em[i+1]), nowAboveMid=(ef[i]>em[i]);
      bool wasAboveMid=(ef[i+1]>=em[i+1]), nowBelowMid=(ef[i]<em[i]);
      bool goldenCross=wasBelowMid&&nowAboveMid, deathCross=wasAboveMid&&nowBelowMid;
      if(!goldenCross&&!deathCross) continue;

      int bi=bars-1-i;
      int xDot=PL+(int)(bi*barW+barW*0.5);
      double midPrice=(ef[i]+em[i])*0.5;
      int yDot=MathMax(PT+6,MathMin(H-PB-6,PT+(int)((mx-midPrice)/range*cH)));

      uint dotC=goldenCross?ColorToARGB(C_GREEN,245):ColorToARGB(C_RED,245);
      gEmaCanvas.FillCircle(xDot,yDot,5,dotC);
      gEmaCanvas.Circle(xDot,yDot,5,ColorToARGB(C'210,218,238',200));

      string priceStr=DoubleToString(midPrice,2);
      uint lblC=goldenCross?ColorToARGB(C_GREEN,255):ColorToARGB(C_RED,255);
      int lblH=12, yLbl=goldenCross?yDot-5-2-lblH:yDot+5+2;
      yLbl=MathMax(PT,MathMin(H-PB-lblH,yLbl));
      int lblW=(int)StringLen(priceStr)*8;
      int xLbl=MathMax(PL,MathMin(W-PR-lblW,xDot-lblW/2));
      gEmaCanvas.FillRectangle(xLbl-3,yLbl-1,xLbl+lblW+2,yLbl+lblH+1,ColorToARGB(C'5,9,17',210));
      gEmaCanvas.FontSet("Arial Bold",9);
      gEmaCanvas.TextOut(xLbl,yLbl,priceStr,lblC);
   }

   double cp=SymbolInfoDouble(gSym,SYMBOL_BID);
   int yP=MathMax(PT,MathMin(H-PB,PT+(int)((mx-cp)/range*cH)));
   for(int x=PL;x<W-PR;x+=6)
   {
      gEmaCanvas.PixelSet(x,  yP,ColorToARGB(C'160,168,195',160));
      gEmaCanvas.PixelSet(x+1,yP,ColorToARGB(C'160,168,195',160));
   }

   gEmaCanvas.FillCircle(W-52,PT+5,3,ColorToARGB(C_YELLOW,230));
   gEmaCanvas.FillCircle(W-36,PT+5,3,ColorToARGB(C_CYAN,  220));
   gEmaCanvas.FillCircle(W-20,PT+5,3,ColorToARGB(C_ORANGE,210));
   gEmaCanvas.Update();
}

