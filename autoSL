//  ╚══════════════════════════════════════════════════════════════════╝
//
#define DASH_SCALE  120

//======================================================================
//  SCALING ENGINE  (không cần chỉnh, chạy tự động theo DASH_SCALE)
//======================================================================

// Macro scale dùng cho #define khác (compile-time)
// Làm tròn: (n * scale + 50) / 100
#define _SZ(n)   ((int)(((long)(n) * (DASH_SCALE) + 50L) / 100L))

// Font scale: min 6pt (MT5 không cho nhỏ hơn)
#define _FS(n)   (_SZ(n) < 6 ? 6 : _SZ(n))

// Hàm runtime (dùng trong code, hỗ trợ biểu thức phức tạp hơn)
int sz(int n){ return (int)(((long)n*(DASH_SCALE)+50L)/100L); }
int fs(int n){ int v=(int)(((long)n*(DASH_SCALE)+50L)/100L); return v<6?6:v; }

//======================================================================
//  KÍCH THƯỚC CƠ SỞ (thiết kế tại DASH_SCALE = 100)
//  → TẤT CẢ tự scale khi thay đổi DASH_SCALE
//======================================================================

