//----------------------------------------------------------------------
//  Btn — căn giữa chữ theo chiều ngang dựa trên pixel thực
//  avgCharW: ước lượng pixel/ký tự ở font size fsize (Arial Bold)
//  MT5 không expose text-width API → dùng heuristic: ~0.6 * fsize * scale
//  Tốt hơn nhiều so với StringLen(txt)*fsize cố định
//----------------------------------------------------------------------
void Btn(string n,int x,int y,int w,int h,string txt,color bg,color clr,int fsize)
{
   Rect(n+"_bg",x,y,w,h,bg,C_BDR2,1);
   ObjectCreate(0,n,OBJ_LABEL,0,0,0);

   // Ước lượng chiều rộng text: 0.65 pixel/unit/fontsize (Arial Bold)
   int textW = (int)(StringLen(txt) * fsize * 0.65);
   int offX  = MathMax(2, (w - textW) / 2);
   int offY  = MathMax(1, (h - fsize*2) / 2 + 1);

   ObjectSetInteger(0,n,OBJPROP_XDISTANCE, x + offX);
   ObjectSetInteger(0,n,OBJPROP_YDISTANCE, y + offY);
   ObjectSetString(0,n,OBJPROP_TEXT,txt);    ObjectSetInteger(0,n,OBJPROP_COLOR,clr);
   ObjectSetInteger(0,n,OBJPROP_FONTSIZE,fsize); ObjectSetString(0,n,OBJPROP_FONT,"Arial Bold");
   ObjectSetInteger(0,n,OBJPROP_CORNER,CORNER_LEFT_UPPER);
   ObjectSetInteger(0,n,OBJPROP_SELECTABLE,true); ObjectSetInteger(0,n,OBJPROP_BACK,false);
   ObjectSetInteger(0,n,OBJPROP_ZORDER,20); Track(n);
}

