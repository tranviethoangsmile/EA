bool InitCanvas()
{
   if(gCanvasReady){ gEmaCanvas.Destroy(); gCanvasReady = false; }

   // eby = InpPanelY + (py+48 cards_y) + 52(ch) + 8(gap) + 12(label) = InpPanelY+120
   // Canvas starts at eby + 22 (after sub-header)
   int cx = InpPanelX + 8;
   int cy = InpPanelY + 142;   // 120 + 22

   if(!gEmaCanvas.CreateBitmapLabel(0, 0, CANVAS_NAME, cx, cy, CANVAS_W, CANVAS_H, COLOR_FORMAT_ARGB_NORMALIZE))
      return false;

   ObjectSetInteger(0, CANVAS_NAME, OBJPROP_CORNER,     CORNER_LEFT_UPPER);
   ObjectSetInteger(0, CANVAS_NAME, OBJPROP_SELECTABLE, false);
   ObjectSetInteger(0, CANVAS_NAME, OBJPROP_BACK,       false);
   ObjectSetInteger(0, CANVAS_NAME, OBJPROP_ZORDER,     5);
   Track(CANVAS_NAME);
   gCanvasReady = true;
   DrawEmaCanvas();
   return true;
}

//----------------------------------------------------------------------
void DrawEmaCanvas()
{
   if(!gCanvasReady) return;

   int W = CANVAS_W, H = CANVAS_H;
   int bars = CANVAS_BARS;

   // ── Fetch EMA data only ─────────────────────────────────────────
   double ef[], em[], es[];
   ArraySetAsSeries(ef,true); ArraySetAsSeries(em,true); ArraySetAsSeries(es,true);
   if(CopyBuffer(hFast,0,0,bars,ef)<bars) return;
   if(CopyBuffer(hMid, 0,0,bars,em)<bars) return;
   if(CopyBuffer(hSlow,0,0,bars,es)<bars) return;

   // ── Price range (EMA values only) ───────────────────────────────
   double mn=DBL_MAX, mx=-DBL_MAX;
   for(int i=0;i<bars;i++)
   {
      mn = MathMin(mn, MathMin(ef[i], MathMin(em[i], es[i])));
      mx = MathMax(mx, MathMax(ef[i], MathMax(em[i], es[i])));
   }
   double range = mx - mn;
   if(range <= 0) return;
   double pad = range * 0.10;
   mn -= pad; mx += pad; range = mx - mn;

   // ── Layout ──────────────────────────────────────────────────────
   const int PL=4, PR=4, PT=5, PB=5;
   int cW = W - PL - PR;
   int cH = H - PT - PB;
   double barW = (double)cW / bars;

   // ── Clear background ────────────────────────────────────────────
   gEmaCanvas.Erase(ColorToARGB(C'5,9,17',255));

   // ── Horizontal grid (4 levels, dotted) ──────────────────────────
   uint gridC = ColorToARGB(C'22,30,50',255);
   for(int g=1;g<=3;g++)
   {
      int gy = PT + g*cH/4;
      for(int x=PL; x<W-PR; x+=5)
         gEmaCanvas.PixelSet(x, gy, gridC);
   }

   // ── Vertical grid every 10 bars ─────────────────────────────────
   for(int vb=10; vb<bars; vb+=10)
   {
      int gx = PL + (int)((bars-vb)*barW + barW*0.5);
      for(int y=PT; y<H-PB; y+=5)
         gEmaCanvas.PixelSet(gx, y, gridC);
   }

   // ── EMA lines (Slow first so Fast draws on top) ──────────────────
   uint cF = ColorToARGB(C_YELLOW, 230);
   uint cM = ColorToARGB(C_CYAN,   220);
   uint cS = ColorToARGB(C_ORANGE, 200);

   for(int i=bars-2; i>=0; i--)
   {
      int bi0 = bars-1-(i+1);   // older bar → left
      int bi1 = bars-1-i;       // newer bar → right
      int xa = PL + (int)(bi0*barW + barW*0.5);
      int xb = PL + (int)(bi1*barW + barW*0.5);

      int yS0 = MathMax(PT,MathMin(H-PB, PT+(int)((mx-es[i+1])/range*cH)));
      int yS1 = MathMax(PT,MathMin(H-PB, PT+(int)((mx-es[i])  /range*cH)));
      int yM0 = MathMax(PT,MathMin(H-PB, PT+(int)((mx-em[i+1])/range*cH)));
      int yM1 = MathMax(PT,MathMin(H-PB, PT+(int)((mx-em[i])  /range*cH)));
      int yF0 = MathMax(PT,MathMin(H-PB, PT+(int)((mx-ef[i+1])/range*cH)));
      int yF1 = MathMax(PT,MathMin(H-PB, PT+(int)((mx-ef[i])  /range*cH)));

      gEmaCanvas.Line(xa, yS0, xb, yS1, cS);
      gEmaCanvas.Line(xa, yM0, xb, yM1, cM);
      gEmaCanvas.Line(xa, yF0, xb, yF1, cF);
   }

   // ── Crossover signal dots + price label ─────────────────────────
   // Golden cross (Fast crosses ABOVE Mid) → BUY  → green dot
   // Death cross  (Fast crosses BELOW Mid) → SELL → red dot
   for(int i=bars-2; i>=1; i--)
   {
      bool wasBelowMid = (ef[i+1] <= em[i+1]);
      bool nowAboveMid = (ef[i]   >  em[i]);
      bool wasAboveMid = (ef[i+1] >= em[i+1]);
      bool nowBelowMid = (ef[i]   <  em[i]);

      bool goldenCross = wasBelowMid && nowAboveMid;
      bool deathCross  = wasAboveMid && nowBelowMid;

      if(!goldenCross && !deathCross) continue;

      // ── Dot position ─────────────────────────────────────────────
      int bi   = bars-1-i;
      int xDot = PL + (int)(bi*barW + barW*0.5);

      double midPrice = (ef[i] + em[i]) * 0.5;
      int yDot = MathMax(PT+6, MathMin(H-PB-6, PT+(int)((mx-midPrice)/range*cH)));

      // ── Draw dot ─────────────────────────────────────────────────
      uint dotC  = goldenCross ? ColorToARGB(C_GREEN,245) : ColorToARGB(C_RED,245);
      uint ringC = ColorToARGB(C'210,218,238',200);
      gEmaCanvas.FillCircle(xDot, yDot, 5, dotC);
      gEmaCanvas.Circle(xDot, yDot, 5, ringC);

      // ── Price label ───────────────────────────────────────────────
      // Format: 2 decimals (gold is usually XXXX.XX)
      string priceStr = DoubleToString(midPrice, 2);
      uint lblC = goldenCross ? ColorToARGB(C_GREEN,255) : ColorToARGB(C_RED,255);

      // Label Y: place ABOVE dot for BUY, BELOW for SELL
      // so it doesn't overlap the dot (dot radius=5 + 2px gap + ~8px font height)
      int lblH = 12;   // approximate text height in pixels
      int yLbl;
      if(goldenCross) yLbl = yDot - 5 - 2 - lblH;
      else            yLbl = yDot + 5 + 2;

      yLbl = MathMax(PT, MathMin(H - PB - lblH, yLbl));

      int lblW = (int)StringLen(priceStr) * 8;
      int xLbl = xDot - lblW/2;
      xLbl = MathMax(PL, MathMin(W - PR - lblW, xLbl));

      gEmaCanvas.FillRectangle(xLbl-3, yLbl-1, xLbl+lblW+2, yLbl+lblH+1, ColorToARGB(C'5,9,17',210));

      gEmaCanvas.FontSet("Arial Bold", 9);
      gEmaCanvas.TextOut(xLbl, yLbl, priceStr, lblC);
   }

   // ── Current price dashed line ────────────────────────────────────
   double cp = SymbolInfoDouble(gSym, SYMBOL_BID);
   int yP = PT + (int)((mx-cp)/range*cH);
   yP = MathMax(PT, MathMin(H-PB, yP));
   for(int x=PL; x<W-PR; x+=6)
   {
      gEmaCanvas.PixelSet(x,   yP, ColorToARGB(C'160,168,195',160));
      gEmaCanvas.PixelSet(x+1, yP, ColorToARGB(C'160,168,195',160));
   }

   // ── Legend dots (top-right) ──────────────────────────────────────
   gEmaCanvas.FillCircle(W-52, PT+5, 3, ColorToARGB(C_YELLOW,230));
   gEmaCanvas.FillCircle(W-36, PT+5, 3, ColorToARGB(C_CYAN,  220));
   gEmaCanvas.FillCircle(W-20, PT+5, 3, ColorToARGB(C_ORANGE,210));

   gEmaCanvas.Update();
}

//======================================================================
//  EVENT HANDLERS
//======================================================================
void OnTick()  { PanelUpdate(); }

void OnTimer()
{
   if(!gBatchRunning)
   {
      DoSetSL();
      if(InpBEEnabled) DoBreakeven();
      if(InpAutoClose) DoAutoClose();
   }
   // Redraw canvas only on new M5 bar (not every second)
   datetime curBar = iTime(gSym, PERIOD_M5, 0);
   if(curBar != gLastM5Bar){ gLastM5Bar = curBar; DrawEmaCanvas(); }
   PanelUpdate();
}

void OnTradeTransaction(const MqlTradeTransaction& t,
                        const MqlTradeRequest& r,
                        const MqlTradeResult& s)
{
   if(t.type == TRADE_TRANSACTION_DEAL_ADD && !gBatchRunning){ Sleep(300); DoSetSL(); }
}

void OnChartEvent(const int id,const long& lp,const double& dp,const string& sp)
{
   if(id != CHARTEVENT_OBJECT_CLICK) return;

   // ── Hide/Show toggle ────────────────────────────────────────────
   if(sp == "d_btn_hide")
   {
      gHidden = !gHidden;
      PanelToggle();
      ObjTxt("d_btn_hide", gHidden ? "[ SHOW ]" : "[ HIDE ]");
      if(gCanvasReady)
         ObjectSetInteger(0, CANVAS_NAME, OBJPROP_TIMEFRAMES, gHidden ? OBJ_NO_PERIODS : OBJ_ALL_PERIODS);
      ChartRedraw(0);
      return;
   }

   // ── EMA period buttons ──────────────────────────────────────────
   bool changed = false;

   // Fast: step 1, min 2, must stay < Mid-1
   if(sp == "d_btn_f_dec")
   {
      if(gEmaFast > 2){ gEmaFast -= 1; if(gEmaFast >= gEmaMid) gEmaFast = gEmaMid-1; if(gEmaFast<2)gEmaFast=2; changed=true; }
   }
   if(sp == "d_btn_f_inc")
   {
      gEmaFast += 1;
      if(gEmaFast >= gEmaMid) gEmaFast = gEmaMid-1;
      if(gEmaFast < 2) gEmaFast = 2;
      changed = true;
   }

   // Mid: step 1, must stay > Fast+1 and < Slow-1
   if(sp == "d_btn_m_dec")
   {
      if(gEmaMid > gEmaFast+1){ gEmaMid -= 1; if(gEmaMid<=gEmaFast)gEmaMid=gEmaFast+1; changed=true; }
   }
   if(sp == "d_btn_m_inc")
   {
      gEmaMid += 1;
      if(gEmaMid >= gEmaSlow) gEmaMid = gEmaSlow-1;
      if(gEmaMid <= gEmaFast) gEmaMid = gEmaFast+1;
      changed = true;
   }

   // Slow: step 1, must stay > Mid+1
   if(sp == "d_btn_s_dec")
   {
      if(gEmaSlow > gEmaMid+1){ gEmaSlow -= 1; changed=true; }
   }
   if(sp == "d_btn_s_inc")
   {
      gEmaSlow += 1; changed=true;
   }

   if(changed)
   {
      ReinitEmaHandles();
      // Update period labels
      ObjTxt("d_ema_fval", (string)gEmaFast);
      ObjTxt("d_ema_mval", (string)gEmaMid);
      ObjTxt("d_ema_sval", (string)gEmaSlow);
      // Update section caption
      ObjTxt("d_s_ema", StringFormat("EMA ANALYSIS  —  M5  ( %d / %d / %d )", gEmaFast, gEmaMid, gEmaSlow));
      // Sub-header
      ObjTxt("d_ema_shl", StringFormat("M5  %d / %d / %d", gEmaFast, gEmaMid, gEmaSlow));
      Log(StringFormat("EMA changed: %d/%d/%d", gEmaFast, gEmaMid, gEmaSlow),"info");
      Sleep(300);  // let handles warm up
      DrawEmaCanvas();
      ChartRedraw(0);
   }
}

//======================================================================
//  HELPERS
//======================================================================
double H1High() { double a[]; ArraySetAsSeries(a,true); if(CopyHigh(gSym,PERIOD_H1,0,1,a)<1) return 0; return a[0]; }
double H1Low()  { double a[]; ArraySetAsSeries(a,true); if(CopyLow( gSym,PERIOD_H1,0,1,a)<1) return 0; return a[0]; }
int    CntPos() { int c=0; for(int i=0;i<PositionsTotal();i++) if(posInfo.SelectByIndex(i)&&posInfo.Symbol()==gSym) c++; return c; }
int    MnLeft() { MqlDateTime d; TimeToStruct(TimeCurrent(),d); int v=InpCloseMinute-d.min; if(v<0)v+=60; return v; }
double TotPnL() { double p=0; for(int i=0;i<PositionsTotal();i++) if(posInfo.SelectByIndex(i)&&posInfo.Symbol()==gSym) p+=posInfo.Profit()+posInfo.Swap()+posInfo.Commission(); return p; }
double USD2Pt(double usd,double lot){ if(lot<=0)return 0; double tv=SymbolInfoDouble(gSym,SYMBOL_TRADE_TICK_VALUE),ts=SymbolInfoDouble(gSym,SYMBOL_TRADE_TICK_SIZE); if(tv<=0||ts<=0)return 0; return usd*ts/(tv*lot); }

bool InSL(ulong t){ for(int i=0;i<ArraySize(tickSL);i++) if(tickSL[i]==t) return true; return false; }
bool InBE(ulong t){ for(int i=0;i<ArraySize(tickBE);i++) if(tickBE[i]==t) return true; return false; }
void AddSL(ulong t){ if(InSL(t))return; int s=ArraySize(tickSL); ArrayResize(tickSL,s+1); tickSL[s]=t; }
void AddBE(ulong t){ if(InBE(t))return; int s=ArraySize(tickBE); ArrayResize(tickBE,s+1); tickBE[s]=t; }
void AddCL(ulong t){ int s=ArraySize(tickCL); ArrayResize(tickCL,s+1); tickCL[s]=t; }

void CleanTicks()
{
   ulong a[]; int c=0;
   for(int i=0;i<ArraySize(tickSL);i++) if(PositionSelectByTicket(tickSL[i])){ ArrayResize(a,c+1); a[c++]=tickSL[i]; }
   ArrayResize(tickSL,c); for(int i=0;i<c;i++) tickSL[i]=a[i];
   ulong b[]; int bc=0;
   for(int i=0;i<ArraySize(tickBE);i++) if(PositionSelectByTicket(tickBE[i])){ ArrayResize(b,bc+1); b[bc++]=tickBE[i]; }
   ArrayResize(tickBE,bc); for(int i=0;i<bc;i++) tickBE[i]=b[i];
}

bool ModRetry(ulong tk,double sl,double tp)
{
   for(int a=1;a<=InpRetryCount;a++)
   {
      if(trade.PositionModify(tk,sl,tp)) return true;
      uint rc=trade.ResultRetcode();
      if(rc==TRADE_RETCODE_INVALID_STOPS||rc==TRADE_RETCODE_TRADE_DISABLED||rc==TRADE_RETCODE_MARKET_CLOSED) return false;
      if(a<InpRetryCount) Sleep(InpRetryDelay);
   }
   return false;
}
bool ClsRetry(ulong tk)
{
   for(int a=1;a<=InpRetryCount;a++)
   {
      if(trade.PositionClose(tk,ULONG_MAX)) return true;
      if(!PositionSelectByTicket(tk)) return true;
      uint rc=trade.ResultRetcode();
      if(rc==TRADE_RETCODE_TRADE_DISABLED||rc==TRADE_RETCODE_MARKET_CLOSED) return false;
      if(a<InpRetryCount) Sleep(InpRetryDelay);
   }
   return false;
}

//======================================================================
//  CORE LOGIC
//======================================================================
void DoSetSL()
{
   double h1h=H1High(); if(h1h<=0) return;
   double h1l=H1Low();  if(h1l<=0) return;
   double pt=SymbolInfoDouble(gSym,SYMBOL_POINT);
   int    dg=(int)SymbolInfoInteger(gSym,SYMBOL_DIGITS);
   double slS=NormalizeDouble(h1h+InpExtraPoints*pt,dg);
   double slB=NormalizeDouble(h1l-InpExtraPoints*pt,dg);

   ulong need[]; int nc=0;
   for(int i=PositionsTotal()-1;i>=0;i--)
   {
      if(!posInfo.SelectByIndex(i)||posInfo.Symbol()!=gSym) continue;
      int tp=(int)posInfo.PositionType(); ulong tk=posInfo.Ticket(); double cs=posInfo.StopLoss();
      if(InpOnlyBuy&&tp!=POSITION_TYPE_BUY) continue;
      if(InpOnlySell&&tp!=POSITION_TYPE_SELL) continue;
      double tSL=(tp==POSITION_TYPE_BUY)?slB:slS;
      bool done=InSL(tk);
      if(cs!=0&&!InpOverwriteSL&&done) continue;
      if(MathAbs(cs-tSL)<pt*0.5&&done) continue;
      if(InBE(tk)){ if(tp==POSITION_TYPE_BUY&&cs>=tSL) continue; if(tp==POSITION_TYPE_SELL&&cs<=tSL) continue; }
      ArrayResize(need,nc+1); need[nc++]=tk;
   }
   if(nc==0){ CleanTicks(); return; }

   gBatchRunning=true;
   int ok=0,fail=0;
   for(int i=0;i<nc;i++)
   {
      if(!PositionSelectByTicket(need[i])) continue;
      int tp=(int)PositionGetInteger(POSITION_TYPE);
      double tSL=(tp==POSITION_TYPE_BUY)?slB:slS;
      double tp2=PositionGetDouble(POSITION_TP);
      if(ModRetry(need[i],tSL,tp2)){ ok++; statSLOk++; AddSL(need[i]); }
      else{ fail++; statSLFail++; Log(StringFormat("FAIL SL #%I64u",need[i]),"err"); }
      if(i<nc-1&&InpBatchDelay>0) Sleep(InpBatchDelay);
   }
   gBatchRunning=false;
   Log(StringFormat("SL: %d OK / %d FAIL | BUY=%.2f SELL=%.2f",ok,fail,slB,slS),ok>0?"ok":"err");
   if(InpAlertOnSet&&ok>0) Alert(StringFormat("[AutoSL] %d lenh | BUY SL=%.2f | SELL SL=%.2f",ok,slB,slS));
   CleanTicks();
}

void DoBreakeven()
{
   int dg=(int)SymbolInfoInteger(gSym,SYMBOL_DIGITS);
   for(int i=PositionsTotal()-1;i>=0;i--)
   {
      if(!posInfo.SelectByIndex(i)||posInfo.Symbol()!=gSym) continue;
      int tp=(int)posInfo.PositionType(); ulong tk=posInfo.Ticket();
      double lot=posInfo.Volume(),entry=posInfo.PriceOpen(),cSL=posInfo.StopLoss(),cTP=posInfo.TakeProfit();
      double pnl=posInfo.Profit()+posInfo.Swap()+posInfo.Commission();
      if((InpOnlyBuy&&tp!=POSITION_TYPE_BUY)||(InpOnlySell&&tp!=POSITION_TYPE_SELL)) continue;
      if(InBE(tk)||pnl<InpBETrigger) continue;
      double off=USD2Pt(InpBELock,lot); if(off<=0) continue;
      double newSL=0;
      if(tp==POSITION_TYPE_BUY){ newSL=NormalizeDouble(entry+off,dg); if(cSL>=newSL) continue; }
      else                     { newSL=NormalizeDouble(entry-off,dg); if(cSL>0&&cSL<=newSL) continue; }
      if(ModRetry(tk,newSL,cTP))
      {
         statBEOk++; AddBE(tk);
         string dir=(tp==POSITION_TYPE_BUY)?"BUY":"SELL";
         Log(StringFormat("BE+ #%I64u %s $%.2f >> SL=%.2f (+$%.2f)",tk,dir,pnl,newSL,InpBELock),"ok");
         Alert(StringFormat("[BE+] #%I64u %s | Lai=$%.2f | SL=%.2f | Lock +$%.2f",tk,dir,pnl,newSL,InpBELock));
      }
   }
}

void DoAutoClose()
{
   MqlDateTime dt; TimeToStruct(TimeCurrent(),dt); int cm=dt.min;
   if(gCloseTrig&&cm!=InpCloseMinute) gCloseTrig=false;
   int ml=InpCloseMinute-cm; if(ml<0)ml+=60;
   if(ml>0&&ml<=InpCloseWarning&&gLastWarnMn!=cm)
   { int cnt=CntPos(); if(cnt>0){ Log(StringFormat("CANH BAO: %d phut | %d lenh",ml,cnt),"warn"); gLastWarnMn=cm; } }
   if(cm!=InpCloseMinute||gCloseTrig) return;

   ulong tc[]; int tcc=0;
   for(int i=PositionsTotal()-1;i>=0;i--)
   {
      if(!posInfo.SelectByIndex(i)||posInfo.Symbol()!=gSym) continue;
      int tp=(int)posInfo.PositionType();
      if((InpOnlyBuy&&tp!=POSITION_TYPE_BUY)||(InpOnlySell&&tp!=POSITION_TYPE_SELL)) continue;
      ArrayResize(tc,tcc+1); tc[tcc++]=posInfo.Ticket();
   }
   if(tcc==0){ gCloseTrig=true; return; }
   gBatchRunning=true;
   Log(StringFormat("AUTO CLOSE: dong %d lenh @ phut %02d",tcc,InpCloseMinute),"warn");
   int ok=0,fail=0;
   for(int i=0;i<tcc;i++)
   {
      if(ClsRetry(tc[i])){ ok++; statClOk++; AddCL(tc[i]); }
      else{ fail++; statClFail++; }
      if(i<tcc-1&&InpBatchDelay>0) Sleep(InpBatchDelay);
   }
   gBatchRunning=false; gCloseTrig=true; gLastCloseMn=cm;
   Log(StringFormat("Close: %d OK / %d FAIL",ok,fail),ok>0?"ok":"err");
   if(InpAlertOnClose) Alert(StringFormat("[AutoClose] %d/%d lenh @ phut %02d",ok,tcc,InpCloseMinute));
}

//======================================================================
//  EMA M5 ANALYSIS
//======================================================================
struct EmaSnap { double f,m,s,fp,mp,sp,price; };
struct Signal  { string trend,sig,str,reason; color tc,sc; int score; };

bool GetEMA(EmaSnap& e)
{
   double f[],m[],s[];
   ArraySetAsSeries(f,true); ArraySetAsSeries(m,true); ArraySetAsSeries(s,true);
   if(CopyBuffer(hFast,0,0,3,f)<3||CopyBuffer(hMid,0,0,3,m)<3||CopyBuffer(hSlow,0,0,3,s)<3) return false;
   e.f=f[0];e.fp=f[1]; e.m=m[0];e.mp=m[1]; e.s=s[0];e.sp=s[1];
   e.price=SymbolInfoDouble(gSym,SYMBOL_BID);
   return true;
}

Signal Analyze(EmaSnap& e)
{
   Signal r;
   r.score=50;
   bool fAboveM=e.f>e.m, fAboveS=e.f>e.s, mAboveS=e.m>e.s;
   bool pAboveF=e.price>e.f, pAboveM=e.price>e.m, pAboveS=e.price>e.s;
   bool fRising=e.f>e.fp, mRising=e.m>e.mp;
   bool golden=(e.f>e.m)&&(e.fp<=e.mp);
   bool death =(e.f<e.m)&&(e.fp>=e.mp);

   if(fAboveM) r.score+=10; else r.score-=10;
   if(fAboveS) r.score+=12; else r.score-=12;
   if(mAboveS) r.score+=10; else r.score-=10;
   if(pAboveF) r.score+=6;  else r.score-=6;
   if(pAboveM) r.score+=6;  else r.score-=6;
   if(pAboveS) r.score+=6;  else r.score-=6;
   if(fRising) r.score+=5;  else r.score-=5;
   if(mRising) r.score+=5;  else r.score-=5;
   r.score=MathMax(0,MathMin(100,r.score));

   if(r.score>=65)      { r.trend="BULLISH"; r.tc=C_GREEN;  }
   else if(r.score<=35) { r.trend="BEARISH"; r.tc=C_RED;    }
   else                 { r.trend="SIDEWAY"; r.tc=C_ORANGE; }

   if(golden&&mAboveS)
   { r.sig="BUY";  r.sc=C_GREEN;  r.str="MANH";       r.reason=StringFormat("Golden Cross EMA%d/%d | Stack bullish M5",gEmaFast,gEmaMid); }
   else if(death&&!mAboveS)
   { r.sig="SELL"; r.sc=C_RED;    r.str="MANH";       r.reason=StringFormat("Death Cross EMA%d/%d | Stack bearish M5",gEmaFast,gEmaMid); }
   else if(r.trend=="BULLISH"&&pAboveF&&pAboveM&&fAboveS)
   { r.sig="BUY";  r.sc=C_GREEN;  r.str="TRUNG BINH"; r.reason=StringFormat("Gia > EMA%d & EMA%d | Xu huong tang M5",gEmaFast,gEmaMid); }
   else if(r.trend=="BEARISH"&&!pAboveF&&!pAboveM&&!fAboveS)
   { r.sig="SELL"; r.sc=C_RED;    r.str="TRUNG BINH"; r.reason=StringFormat("Gia < EMA%d & EMA%d | Xu huong giam M5",gEmaFast,gEmaMid); }
   else if(r.trend=="BULLISH"&&!pAboveF&&pAboveM)
   { r.sig="BUY";  r.sc=C_YELLOW; r.str="YEU";        r.reason=StringFormat("Pullback EMA%d | Cho nen xac nhan M5",gEmaFast); }
   else if(r.trend=="BEARISH"&&pAboveF&&!pAboveM)
   { r.sig="SELL"; r.sc=C_YELLOW; r.str="YEU";        r.reason=StringFormat("Pullback EMA%d | Cho nen xac nhan M5",gEmaFast); }
   else
   { r.sig="WAIT"; r.sc=C_ORANGE; r.str="---";        r.reason="EMA M5 chua xac dinh xu huong ro rang"; }
   return r;
}

//======================================================================
//  LOG
//======================================================================
void Log(string msg,string typ)
{
   MqlDateTime d; TimeToStruct(TimeCurrent(),d);
   string ts=StringFormat("%02d:%02d:%02d",d.hour,d.min,d.sec);
   string line="["+ts+"] "+msg+"|"+typ;
   int sz=ArraySize(gLog);
   if(sz>=InpMaxLog){ for(int i=0;i<sz-1;i++) gLog[i]=gLog[i+1]; gLog[sz-1]=line; }
   else{ ArrayResize(gLog,sz+1); gLog[sz]=line; }
   Print("[EA] "+msg);
}

//======================================================================
//  DRAWING ENGINE
//======================================================================
void Track(string n)
{
   int s=ArraySize(gObjs);
   for(int i=0;i<s;i++) if(gObjs[i]==n) return;
   ArrayResize(gObjs,s+1); gObjs[s]=n;
}
void ObjDeleteAll()
{
   for(int i=0;i<ArraySize(gObjs);i++) ObjectDelete(0,gObjs[i]);
   ArrayResize(gObjs,0); ChartRedraw(0);
}

void Rect(string n,int x,int y,int w,int h,color bg,color bd,int bw=1)
{
   ObjectCreate(0,n,OBJ_RECTANGLE_LABEL,0,0,0);
   ObjectSetInteger(0,n,OBJPROP_XDISTANCE,x); ObjectSetInteger(0,n,OBJPROP_YDISTANCE,y);
   ObjectSetInteger(0,n,OBJPROP_XSIZE,w);     ObjectSetInteger(0,n,OBJPROP_YSIZE,h);
   ObjectSetInteger(0,n,OBJPROP_BGCOLOR,bg);  ObjectSetInteger(0,n,OBJPROP_COLOR,bd);
   ObjectSetInteger(0,n,OBJPROP_BORDER_TYPE,BORDER_FLAT); ObjectSetInteger(0,n,OBJPROP_WIDTH,bw);
   ObjectSetInteger(0,n,OBJPROP_BACK,false);  ObjectSetInteger(0,n,OBJPROP_SELECTABLE,false);
   ObjectSetInteger(0,n,OBJPROP_ZORDER,0); Track(n);
}

void Lbl(string n,int x,int y,string txt,color clr,int fs,bool bold=false)
{
   ObjectCreate(0,n,OBJ_LABEL,0,0,0);
