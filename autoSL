void OnTick()  { PanelUpdate(); }

void OnTimer()
{
   if(!gBatchRunning)
   {
      DoSetSL();
      if(InpBEEnabled) DoBreakeven();
      if(InpAutoClose) DoAutoClose();
   }
   datetime curBar = iTime(gSym, PERIOD_M5, 0);
   if(curBar != gLastM5Bar){ gLastM5Bar = curBar; DrawEmaCanvas(); }
   PanelUpdate();
}

void OnTradeTransaction(const MqlTradeTransaction& t,
                        const MqlTradeRequest& r,
                        const MqlTradeResult& s)
{
   if(t.type == TRADE_TRANSACTION_DEAL_ADD && !gBatchRunning){ Sleep(300); DoSetSL(); }
}

void OnChartEvent(const int id,const long& lp,const double& dp,const string& sp)
{
   if(id != CHARTEVENT_OBJECT_CLICK) return;

   //--------------------------------------------------------------------
   //  HIDE / SHOW
   //--------------------------------------------------------------------
   if(sp == "d_btn_hide")
   {
      gHidden = !gHidden;
      PanelToggle();
      ObjTxt("d_btn_hide", gHidden ? "[ SHOW ]" : "[ X ]");
      if(gCanvasReady)
         ObjectSetInteger(0,CANVAS_NAME,OBJPROP_TIMEFRAMES,gHidden?OBJ_NO_PERIODS:OBJ_ALL_PERIODS);
      ChartRedraw(0);
      return;
   }

   //--------------------------------------------------------------------
   //  SCALE BUTTONS  — S / M / L / XL
   //  Rebuild toàn bộ panel + canvas ngay lập tức
   //--------------------------------------------------------------------
   int newScale = 0;
   if(sp == "d_btn_sc_s" ) newScale = 80;
   if(sp == "d_btn_sc_m" ) newScale = 100;
   if(sp == "d_btn_sc_l" ) newScale = 120;
   if(sp == "d_btn_sc_xl") newScale = 150;

   if(newScale > 0 && newScale != gDashScale)
   {
      gDashScale = newScale;
      Log(StringFormat("Scale → %d%%", gDashScale), "info");
      // Rebuild toàn bộ panel + canvas với scale mới
      BuildPanel();
      if(gCanvasReady){ gEmaCanvas.Destroy(); gCanvasReady = false; }
      if(!InitCanvas()) Log("Canvas init failed after scale change","err");
      DrawEmaCanvas();
      ChartRedraw(0);
      return;
   }

   //--------------------------------------------------------------------
   //  EMA PERIOD BUTTONS
   //--------------------------------------------------------------------
   bool changed = false;
   if(sp=="d_btn_f_dec"){ if(gEmaFast>2){ gEmaFast-=1; if(gEmaFast>=gEmaMid) gEmaFast=gEmaMid-1; if(gEmaFast<2)gEmaFast=2; changed=true; } }
   if(sp=="d_btn_f_inc"){ gEmaFast+=1; if(gEmaFast>=gEmaMid) gEmaFast=gEmaMid-1; if(gEmaFast<2)gEmaFast=2; changed=true; }
   if(sp=="d_btn_m_dec"){ if(gEmaMid>gEmaFast+1){ gEmaMid-=1; if(gEmaMid<=gEmaFast)gEmaMid=gEmaFast+1; changed=true; } }
   if(sp=="d_btn_m_inc"){ gEmaMid+=1; if(gEmaMid>=gEmaSlow)gEmaMid=gEmaSlow-1; if(gEmaMid<=gEmaFast)gEmaMid=gEmaFast+1; changed=true; }
   if(sp=="d_btn_s_dec"){ if(gEmaSlow>gEmaMid+1){ gEmaSlow-=1; changed=true; } }
   if(sp=="d_btn_s_inc"){ gEmaSlow+=1; changed=true; }

   if(changed)
   {
      ReinitEmaHandles();
      ObjTxt("d_ema_fval",(string)gEmaFast);
      ObjTxt("d_ema_mval",(string)gEmaMid);
      ObjTxt("d_ema_sval",(string)gEmaSlow);
      ObjTxt("d_s_ema",StringFormat("EMA ANALYSIS  —  M5  ( %d / %d / %d )",gEmaFast,gEmaMid,gEmaSlow));
      ObjTxt("d_ema_shl",StringFormat("M5  %d / %d / %d",gEmaFast,gEmaMid,gEmaSlow));
      Log(StringFormat("EMA changed: %d/%d/%d",gEmaFast,gEmaMid,gEmaSlow),"info");
      Sleep(300);
      DrawEmaCanvas();
      ChartRedraw(0);
   }
}

//======================================================================
//  HELPERS
//======================================================================
double H1High() { double a[]; ArraySetAsSeries(a,true); if(CopyHigh(gSym,PERIOD_H1,0,1,a)<1) return 0; return a[0]; }
double H1Low()  { double a[]; ArraySetAsSeries(a,true); if(CopyLow( gSym,PERIOD_H1,0,1,a)<1) return 0; return a[0]; }
int    CntPos() { int c=0; for(int i=0;i<PositionsTotal();i++) if(posInfo.SelectByIndex(i)&&posInfo.Symbol()==gSym) c++; return c; }
int    MnLeft() { MqlDateTime d; TimeToStruct(TimeCurrent(),d); int v=InpCloseMinute-d.min; if(v<0)v+=60; return v; }
double TotPnL() { double p=0; for(int i=0;i<PositionsTotal();i++) if(posInfo.SelectByIndex(i)&&posInfo.Symbol()==gSym) p+=posInfo.Profit()+posInfo.Swap()+posInfo.Commission(); return p; }
double USD2Pt(double usd,double lot){ if(lot<=0)return 0; double tv=SymbolInfoDouble(gSym,SYMBOL_TRADE_TICK_VALUE),ts=SymbolInfoDouble(gSym,SYMBOL_TRADE_TICK_SIZE); if(tv<=0||ts<=0)return 0; return usd*ts/(tv*lot); }

bool InSL(ulong t){ for(int i=0;i<ArraySize(tickSL);i++) if(tickSL[i]==t) return true; return false; }
bool InBE(ulong t){ for(int i=0;i<ArraySize(tickBE);i++) if(tickBE[i]==t) return true; return false; }
void AddSL(ulong t){ if(InSL(t))return; int s=ArraySize(tickSL); ArrayResize(tickSL,s+1); tickSL[s]=t; }
void AddBE(ulong t){ if(InBE(t))return; int s=ArraySize(tickBE); ArrayResize(tickBE,s+1); tickBE[s]=t; }
void AddCL(ulong t){ int s=ArraySize(tickCL); ArrayResize(tickCL,s+1); tickCL[s]=t; }

void CleanTicks()
{
   ulong a[]; int c=0;
   for(int i=0;i<ArraySize(tickSL);i++) if(PositionSelectByTicket(tickSL[i])){ ArrayResize(a,c+1); a[c++]=tickSL[i]; }
   ArrayResize(tickSL,c); for(int i=0;i<c;i++) tickSL[i]=a[i];
   ulong b[]; int bc=0;
   for(int i=0;i<ArraySize(tickBE);i++) if(PositionSelectByTicket(tickBE[i])){ ArrayResize(b,bc+1); b[bc++]=tickBE[i]; }
   ArrayResize(tickBE,bc); for(int i=0;i<bc;i++) tickBE[i]=b[i];
}

bool ModRetry(ulong tk,double sl,double tp)
{
   for(int a=1;a<=InpRetryCount;a++)
   {
      if(trade.PositionModify(tk,sl,tp)) return true;
      uint rc=trade.ResultRetcode();
      if(rc==TRADE_RETCODE_INVALID_STOPS||rc==TRADE_RETCODE_TRADE_DISABLED||rc==TRADE_RETCODE_MARKET_CLOSED) return false;
      if(a<InpRetryCount) Sleep(InpRetryDelay);
   }
   return false;
}
bool ClsRetry(ulong tk)
{
   for(int a=1;a<=InpRetryCount;a++)
   {
      if(trade.PositionClose(tk,ULONG_MAX)) return true;
      if(!PositionSelectByTicket(tk)) return true;
      uint rc=trade.ResultRetcode();
      if(rc==TRADE_RETCODE_TRADE_DISABLED||rc==TRADE_RETCODE_MARKET_CLOSED) return false;
      if(a<InpRetryCount) Sleep(InpRetryDelay);
   }
   return false;
}

