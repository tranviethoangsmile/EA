   Lbl("d_cd_lbl", px+11,  dy+5, "CLOSE TIMER:", C_MUTED,7);
   Rect("d_cd_bg", px+102, dy+6, PW-114,8, C'14,20,34',C_BDR);
   Rect("d_cd_fill",px+102,dy+6, 0,     8, C_GREEN,C_GREEN,0);
   Lbl("d_cd_txt", px+110, dy+5, "-- phut nua", C_WHITE,7,true);

   // ── SECTION E: BATCH BAR ──────────────────────────────────────
   int ey=dy+20+4;
   Rect("d_bt_bg",px+5, ey,PW-10,18,C_CARD2,C_BDR);
   Lbl("d_bt_l",  px+11,ey+4,"BATCH:", C_MUTED,7);
   Lbl("d_bt_v",  px+50,ey+4,"STANDBY",C_GREEN,7,true);
   Lbl("d_bt_s1", px+115,ey+4,"|",     C_MUTED2,7);
   Lbl("d_bt_be", px+122,ey+4,
       InpBEEnabled?StringFormat("BE $%.0f>>+$%.0f",InpBETrigger,InpBELock):"BE:OFF",
       InpBEEnabled?C_PURPLE:C_MUTED,7);
   Lbl("d_bt_s2", px+250,ey+4,"|",     C_MUTED2,7);
   Lbl("d_bt_rt", px+257,ey+4,
       StringFormat("Retry %dx%dms | Delay %dms",InpRetryCount,InpRetryDelay,InpBatchDelay),C_MUTED,7);

   // ── SECTION F: LOG ────────────────────────────────────────────
   int fy=ey+18+5;
   Lbl("d_log_l",px+10,fy,"JOURNAL",C_MUTED,7);
   int lgy=fy+11;
   Rect("d_log_bg",px+5,lgy,PW-10,InpMaxLog*RLOG+6,C'8,12,20',C_BDR);
   for(int i=0;i<InpMaxLog;i++)
      Lbl(StringFormat("d_log%d",i),px+10,lgy+3+i*RLOG,"",C_MUTED,7);

   // ── FOOTER ────────────────────────────────────────────────────
   int ffY=lgy+InpMaxLog*RLOG+10;
   Rect("d_ft_bg",  px,ffY, PW,16, C'10,13,20',C_BDR,0);
   Rect("d_ft_line",px,ffY, PW,1,  C_GOLD2,C_GOLD2,0);
   Lbl("d_ft_sym",  px+10, ffY+4, gSym,             C_GOLD,  7,true);
   Lbl("d_ft_s1",   px+50, ffY+4, "|",              C_MUTED2,7);
   Lbl("d_ft_time", px+58, ffY+4, "",               C_MUTED, 7);
   Lbl("d_ft_s2",   px+195,ffY+4, "|",              C_MUTED2,7);
   Lbl("d_ft_srv",  px+203,ffY+4, "copyright by TVH-SMILE - v1.0",C_MUTED, 7);

   ChartRedraw(0);
}

//======================================================================
//  PANEL TOGGLE VISIBILITY
//======================================================================
void PanelToggle()
{
   for(int i=0;i<ArraySize(gObjs);i++)
   {
      string n=gObjs[i];
      if(n=="d_bg"||n=="d_sh"||n=="d_hdr_bg"||n=="d_hdr_line"||
         n=="d_hdr_title"||n=="d_hdr_pipe"||n=="d_hdr_sym"||
         n=="d_hdr_ver"||n=="d_hdr_status"||n=="d_hdr_clock"||
         n=="d_btn_hide"||n=="d_btn_hide_bg") continue;
      ObjVis(n,!gHidden);
   }
}

//======================================================================
//  PANEL UPDATE
//======================================================================
void PanelUpdate()
{
   MqlDateTime dt; TimeToStruct(TimeCurrent(),dt);
   ObjTxt("d_hdr_clock",TimeToString(TimeCurrent(),TIME_SECONDS));

   if(gHidden){ ChartRedraw(0); return; }

   double h1h=H1High(), h1l=H1Low();
   double pt=SymbolInfoDouble(gSym,SYMBOL_POINT);
   int    dg=(int)SymbolInfoInteger(gSym,SYMBOL_DIGITS);
   double slS=NormalizeDouble(h1h+InpExtraPoints*pt,dg);
   double slB=NormalizeDouble(h1l-InpExtraPoints*pt,dg);
   int    pc =CntPos();
   double pnl=TotPnL();
   int    ml =MnLeft();
   bool isClose=(dt.min==InpCloseMinute&&InpAutoClose);
   bool isWarn =(ml<=InpCloseWarning&&ml>0&&InpAutoClose);

   // Header status
   if(gBatchRunning)    { ObjTxt("d_hdr_status","[BUSY]");    ObjClr("d_hdr_status",C_ORANGE); }
   else if(isClose)     { ObjTxt("d_hdr_status","[CLOSING]"); ObjClr("d_hdr_status",C_RED);    }
   else                 { ObjTxt("d_hdr_status","[RUNNING]"); ObjClr("d_hdr_status",C_GREEN);  }

   // Metric cards
   ObjTxt("d_c1v",(string)pc);
   ObjClr("d_c1v",pc>0?C_WHITE:C_MUTED);
   ObjTxt("d_c1s",pc>0?"lenh mo":"trong");

   string ps=(pnl>=0?"+":"")+DoubleToString(pnl,2);
   ObjTxt("d_c2v",ps);
   ObjClr("d_c2v",pnl>0?C_GREEN:pnl<0?C_RED:C_MUTED);
   ObjectSetInteger(0,"d_c2t",OBJPROP_BGCOLOR,pnl>0?C_GREEN:pnl<0?C_RED:C_BDR);
   ObjectSetInteger(0,"d_c2t",OBJPROP_COLOR,  pnl>0?C_GREEN:pnl<0?C_RED:C_BDR);

   ObjTxt("d_c3v",(string)statSLOk);
   ObjTxt("d_c4v",(string)statBEOk);
   ObjClr("d_c4v",statBEOk>0?C_PURPLE:C_MUTED);

   // ── EMA signal labels (canvas redraws separately on M5 bar) ─────
   EmaSnap ema; Signal sig;
   if(GetEMA(ema))
   {
      sig = Analyze(ema);
      // Trend badge in sub-header
      ObjTxt("d_ema_shbdg", sig.trend); ObjClr("d_ema_shbdg", sig.tc);
      // Signal row
      ObjTxt("d_ema_trv", sig.trend);   ObjClr("d_ema_trv", sig.tc);
      ObjTxt("d_ema_sgv", sig.sig);     ObjClr("d_ema_sgv", sig.sc);
      ObjTxt("d_ema_stv", sig.str);
      ObjClr("d_ema_stv", sig.str=="MANH"?C_GREEN:sig.str=="TRUNG BINH"?C_YELLOW:C_ORANGE);
      ObjTxt("d_ema_rsn", sig.reason);
      // Score
      ObjTxt("d_ema_score_v", (string)sig.score);
      ObjClr("d_ema_score_v", sig.tc);
      // Score bar
      int sbW=(int)((PW-10)*sig.score/100.0);
      ObjW("d_sbar_fill", sbW);
      ObjBg("d_sbar_fill", sig.tc);
      // Also redraw canvas on price change (fast update path)
      // Heavy redraw is handled in OnTimer per M5 bar; here just update price line
      // (skip here; OnTimer handles it)
   }

   // SL card
   ObjTxt("d_sl_bv", DoubleToString(slB,2));
   ObjTxt("d_sl_sv", DoubleToString(slS,2));
   int slt=statSLOk+statSLFail;
   ObjTxt("d_sl_st",StringFormat("%d OK / %d FAIL (%d%%)",statSLOk,statSLFail,slt>0?(int)(statSLOk*100.0/slt):0));
   ObjClr("d_sl_st",statSLFail>0?C_ORANGE:C_GREEN);
   ObjTxt("d_sl_rt",StringFormat("Buffer: %.0f pts",InpExtraPoints));

   // Close card
   string cds; color cdc;
   if(isClose)    { cds="DONG NGAY!";                      cdc=C_RED;    }
   else if(isWarn){ cds=StringFormat("!! %d PHUT !!",ml);  cdc=C_ORANGE; }
   else           { cds=StringFormat("%d phut nua",ml);     cdc=C_CYAN;   }
   ObjTxt("d_cl_cdv",cds); ObjClr("d_cl_cdv",cdc);
   ObjTxt("d_cl_st",StringFormat("%d OK / %d FAIL",statClOk,statClFail));
   ObjClr("d_cl_st",statClFail>0?C_ORANGE:C_GREEN);

   // Countdown bar
   int barMaxW=PW-114;
   int barFill=MathMax(0,MathMin((int)(barMaxW*(1.0-ml/60.0)),barMaxW));
   ObjW("d_cd_fill",barFill);
   color bc=isClose?C_RED:isWarn?C_ORANGE:C_GREEN;
   ObjBg("d_cd_fill",bc);
   int s2c=ml*60-dt.sec; if(s2c<0)s2c=0;
   ObjTxt("d_cd_txt",StringFormat("%02d:%02d den phut :%02d",s2c/60,s2c%60,InpCloseMinute));
   ObjClr("d_cd_txt",bc);

   // Batch bar
   if(gBatchRunning)      { ObjTxt("d_bt_v","PROCESSING..."); ObjClr("d_bt_v",C_ORANGE); }
   else if(isClose&&pc>0) { ObjTxt("d_bt_v","CLOSING ALL");   ObjClr("d_bt_v",C_RED);    }
   else if(isWarn&&pc>0)  { ObjTxt("d_bt_v",StringFormat("WARN -%dmin",ml)); ObjClr("d_bt_v",C_ORANGE); }
   else                   { ObjTxt("d_bt_v","STANDBY");        ObjClr("d_bt_v",C_GREEN);  }

   // Log
   int lsz=ArraySize(gLog);
   for(int i=0;i<InpMaxLog;i++)
   {
      int idx=lsz-InpMaxLog+i;
      if(idx<0||idx>=lsz){ ObjTxt(StringFormat("d_log%d",i),""); continue; }
      string raw=gLog[idx];
      int pipe=StringFind(raw,"|",StringLen(raw)-5);
      string txt=pipe>=0?StringSubstr(raw,0,pipe):raw;
      string typ=pipe>=0?StringSubstr(raw,pipe+1):"info";
      color lc=(typ=="ok")?C_GREEN:(typ=="err")?C_RED:(typ=="warn")?C_ORANGE:C_MUTED;
      ObjTxt(StringFormat("d_log%d",i),txt);
      ObjClr(StringFormat("d_log%d",i),lc);
   }

   ObjTxt("d_ft_time",TimeToString(TimeCurrent(),TIME_DATE|TIME_SECONDS));
   ChartRedraw(0);
}
